---
import MotionOnView from './motion/MotionOnView.tsx';

const features = [
  {
    title: 'Global hotkey',
    body: 'Summon and dismiss from anywhere. Never steals focus.',
    icon: 'hotkey',
  },
  {
    title: 'Autosave',
    body: 'Every keystroke to local SQLite. No save button, no lost work.',
    icon: 'save',
  },
  {
    title: 'Full-text search',
    body: 'FTS5 across every tab and history entry. Answers in milliseconds.',
    icon: 'search',
  },
  {
    title: 'CodeMirror 6 syntax',
    body: 'Rust, TypeScript, Python, Markdown, JSON, YAML and more.',
    icon: 'syntax',
  },
  {
    title: 'Local-only by design',
    body: 'No account, no sync server, no telemetry. One portable SQLite file.',
    icon: 'lock',
  },
  {
    title: 'Command palette',
    body: 'Double-tap Shift. Fuzzy-matched, always discoverable.',
    icon: 'palette',
  },
  {
    title: 'Tabs',
    body: 'Create, close, switch, rename, reorder — all without the mouse.',
    icon: 'tabs',
  },
  {
    title: 'Session recovery',
    body: 'Crash, reboot, close. Tabs, cursor, and scroll state come back.',
    icon: 'recover',
  },
];

const ICONS: Record<string, string> = {
  hotkey:
    '<path d="M8 3h8M8 21h8M4 8v8M20 8v8M4 4h4M16 4h4M4 20h4M16 20h4M7 12h10M7 16h5"/>',
  save:
    '<path d="M5 3h11l3 3v15H5z"/><path d="M9 3v6h7V3"/><path d="M8 15h8v6H8z"/>',
  search:
    '<circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>',
  syntax:
    '<path d="m8 7-5 5 5 5"/><path d="m16 7 5 5-5 5"/><path d="m14 4-4 16"/>',
  lock:
    '<rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/><path d="M12 15v2"/>',
  palette:
    '<rect x="3" y="4" width="18" height="16" rx="3"/><path d="M3 9h18"/><path d="m8 14 2 2 4-4"/>',
  tabs:
    '<path d="M3 7h5l2-2h6l2 2h3v12H3z"/><path d="M8 11h8"/><path d="M8 15h5"/>',
  recover:
    '<path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/><path d="M12 8v5l3 2"/>',
};
---

<section class="section" id="features" aria-labelledby="features-heading">
  <div class="container">
    <header class="section-head">
      <p class="eyebrow">Features</p>
      <h2 id="features-heading">Built for keyboard-driven work</h2>
      <p class="lede">
        Writ is small on purpose. Every feature earns its place by saving you a click,
        a tab switch, or a reach for the mouse.
      </p>
    </header>

    <ul class="feature-grid" role="list">
      {features.map((f, i) => (
        <li class="feature-card-wrap">
          <MotionOnView client:visible delay={0.04 * (i % 4)} as="div">
            <article class="feature-card">
              <div class="feature-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[f.icon]} />
              </div>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </article>
          </MotionOnView>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .feature-card-wrap {
    display: flex;
  }
  .feature-card-wrap > :global(div) {
    width: 100%;
    display: flex;
  }
  .feature-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.4rem 1.4rem 1.25rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--card-shadow);
    width: 100%;
    transition:
      transform var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out);
  }
  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--card-shadow-hover);
    border-color: color-mix(in oklab, var(--accent) 25%, var(--border));
  }
  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    color: var(--accent);
    background: var(--accent-soft);
    border: 1px solid color-mix(in oklab, var(--accent) 24%, transparent);
  }
  .feature-card h3 {
    font-size: 1rem;
    margin: 0;
    color: var(--foreground);
  }
  .feature-card p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--muted-foreground);
  }
</style>
