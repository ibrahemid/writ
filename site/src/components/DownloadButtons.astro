---
import release from '../data/release.json';

interface Props {
  variant?: 'hero' | 'compact';
}

const { variant = 'hero' } = Astro.props;

const buttons = [
  {
    os: 'mac',
    label: 'Download for macOS',
    sub: 'Universal · .dmg',
    href: release.assets['mac-arm64'],
    hrefAlt: release.assets['mac-x64'],
    icon: 'mac',
  },
  {
    os: 'win',
    label: 'Download for Windows',
    sub: 'x64 .msi installer',
    href: release.assets['win-x64'],
    icon: 'win',
  },
  {
    os: 'linux',
    label: 'Download for Linux',
    sub: 'AppImage · .deb',
    href: release.assets['linux-appimage'],
    icon: 'linux',
  },
];
---

<div class={`dl-root dl-root--${variant}`} data-dl-root>
  <div class="dl-primary" data-dl-primary>
    {buttons.map((b) => (
      <a
        class="btn btn-lg dl-btn"
        href={b.href}
        data-os={b.os}
        data-href-arm={b.hrefAlt ?? b.href}
        data-href-x64={b.os === 'mac' ? b.hrefAlt : b.href}
        rel="noopener"
      >
        <span class="dl-icon" aria-hidden="true">
          {b.icon === 'mac' && (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16.365 1.43c0 1.14-.46 2.23-1.21 3.02-.8.83-2.09 1.48-3.14 1.4-.13-1.14.45-2.33 1.18-3.08.82-.83 2.2-1.44 3.17-1.34zM20.5 17.3c-.57 1.32-.84 1.9-1.57 3.06-1.02 1.62-2.46 3.63-4.24 3.65-1.58.02-1.99-1.03-4.14-1.02-2.15.01-2.6 1.04-4.18 1.02-1.78-.02-3.14-1.84-4.16-3.46C-.22 17.2-.62 11.9 1.13 9.15c1.24-1.95 3.2-3.09 5.03-3.09 1.87 0 3.04 1.03 4.58 1.03 1.49 0 2.4-1.03 4.57-1.03 1.64 0 3.37.9 4.6 2.45-4.04 2.22-3.38 8.01.59 8.79z"/></svg>
          )}
          {b.icon === 'win' && (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M3 5.5 11 4.3v7.2H3V5.5Zm0 13v-6h8v7.2L3 18.5Zm9-7h9v9.5l-9-1.3v-8.2Zm0-7.5 9-1.2v8.2h-9V4Z"/></svg>
          )}
          {b.icon === 'linux' && (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c-2.5 0-4 2.5-4 5.5 0 1.2.4 2.2.9 3-.6.7-1.3 1.6-2 2.7-1.4 2.2-2.2 4.2-2.2 5.8 0 .8.4 1.5 1.1 2 .6.4 1.4.5 2.1.2.4.5 1.2.8 2.4.8h3.4c1.2 0 2-.3 2.4-.8.7.3 1.5.2 2.1-.2.7-.5 1.1-1.2 1.1-2 0-1.6-.8-3.6-2.2-5.8-.7-1.1-1.4-2-2-2.7.5-.8.9-1.8.9-3C16 4.5 14.5 2 12 2Zm-1.4 5.2c.3 0 .6.3.6.7 0 .4-.3.7-.6.7-.3 0-.6-.3-.6-.7 0-.4.3-.7.6-.7Zm2.8 0c.3 0 .6.3.6.7 0 .4-.3.7-.6.7-.3 0-.6-.3-.6-.7 0-.4.3-.7.6-.7ZM12 9.2c.6 0 1.1.3 1.3.6.1.1.1.3 0 .4-.2.3-.7.6-1.3.6s-1.1-.3-1.3-.6c-.1-.1-.1-.3 0-.4.2-.3.7-.6 1.3-.6Z"/></svg>
          )}
        </span>
        <span class="dl-text">
          <span class="dl-label">{b.label}</span>
          <span class="dl-sub">{b.sub}</span>
        </span>
      </a>
    ))}
  </div>

  <p class="dl-meta">
    <a class="dl-alt-link" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/download`}>
      All platforms and package managers →
    </a>
    <span class="dl-meta-sep" aria-hidden="true">·</span>
    <span class="dl-version">
      Latest: <strong>v{release.version}</strong>
    </span>
  </p>
</div>

<style>
  .dl-root {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .dl-primary {
    display: grid;
    gap: 0.6rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .dl-root[data-detected] .dl-primary {
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr) minmax(0, 1fr);
  }
  .dl-root[data-detected='mac'] .dl-btn[data-os='mac'],
  .dl-root[data-detected='win'] .dl-btn[data-os='win'],
  .dl-root[data-detected='linux'] .dl-btn[data-os='linux'] {
    order: -1;
    grid-column: 1;
  }
  .dl-btn {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
    text-align: left;
    padding: 0.85rem 1rem;
    min-height: 56px;
  }
  .dl-btn.is-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-foreground);
    box-shadow:
      0 1px 0 rgba(0, 0, 0, 0.05),
      0 12px 28px -10px color-mix(in oklab, var(--accent) 60%, transparent);
  }
  .dl-btn.is-primary:hover {
    background: var(--accent-hover);
    border-color: var(--accent-hover);
    color: var(--accent-foreground);
  }
  .dl-btn.is-primary .dl-icon,
  .dl-btn.is-primary .dl-label,
  .dl-btn.is-primary .dl-sub {
    color: var(--accent-foreground);
  }
  .dl-btn.is-primary .dl-sub {
    opacity: 0.85;
  }
  .dl-icon {
    display: inline-flex;
    color: var(--foreground);
    flex: 0 0 auto;
  }
  .dl-text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    min-width: 0;
  }
  .dl-label {
    font-weight: 500;
    color: var(--foreground);
  }
  .dl-sub {
    font-size: 0.78rem;
    color: var(--muted-foreground);
    margin-top: 2px;
  }
  .dl-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: 0.85rem;
    color: var(--muted-foreground);
  }
  .dl-alt-link {
    color: var(--muted-foreground);
  }
  .dl-alt-link:hover {
    color: var(--accent);
  }
  .dl-meta-sep {
    color: var(--border-strong);
  }
  .dl-version strong {
    color: var(--foreground);
    font-weight: 500;
  }
  @media (max-width: 720px) {
    .dl-primary,
    .dl-root[data-detected] .dl-primary {
      grid-template-columns: 1fr;
    }
    .dl-root[data-detected='mac'] .dl-btn[data-os='mac'],
    .dl-root[data-detected='win'] .dl-btn[data-os='win'],
    .dl-root[data-detected='linux'] .dl-btn[data-os='linux'] {
      grid-column: auto;
    }
  }
</style>

<script>
  type OS = 'mac' | 'win' | 'linux';

  function detectOs(): OS | null {
    if (typeof navigator === 'undefined') return null;
    const nav = navigator as Navigator & { userAgentData?: { platform?: string } };
    const p = (nav.userAgentData?.platform || nav.platform || '').toLowerCase();
    const ua = (navigator.userAgent || '').toLowerCase();
    if (p.includes('mac') || ua.includes('mac os')) return 'mac';
    if (p.includes('win') || ua.includes('windows')) return 'win';
    if (p.includes('linux') || ua.includes('linux')) return 'linux';
    return null;
  }

  function detectMacArch(): 'arm64' | 'x64' {
    const ua = (navigator.userAgent || '').toLowerCase();
    if (ua.includes('intel mac os')) return 'x64';
    return 'arm64';
  }

  const os = detectOs();
  const roots = document.querySelectorAll<HTMLElement>('[data-dl-root]');

  roots.forEach((root) => {
    if (!os) return;
    root.dataset.detected = os;
    const matching = root.querySelector<HTMLAnchorElement>(`.dl-btn[data-os='${os}']`);
    if (!matching) return;
    matching.classList.add('is-primary');

    if (os === 'mac') {
      const arch = detectMacArch();
      const href =
        arch === 'arm64'
          ? matching.dataset.hrefArm || matching.href
          : matching.dataset.hrefX64 || matching.href;
      if (href) matching.href = href;
      const sub = matching.querySelector<HTMLElement>('.dl-sub');
      if (sub) sub.textContent = arch === 'arm64' ? 'Apple Silicon · .dmg' : 'Intel · .dmg';
    }
  });
</script>
