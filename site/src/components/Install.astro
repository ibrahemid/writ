---
const tabs = [
  {
    id: 'mac',
    label: 'macOS',
    sub: 'Homebrew tap, Apple Silicon + Intel',
    cmd: 'brew install ibrahemid/writ/writ',
    alt: 'or download the .dmg →',
    altHref: '/writ/download/#mac',
  },
  {
    id: 'win',
    label: 'Windows',
    sub: 'winget, x86_64',
    cmd: 'winget install ibrahemid.writ',
    alt: 'or download the .msi →',
    altHref: '/writ/download/#win',
  },
  {
    id: 'linux',
    label: 'Linux',
    sub: 'shell installer, x86_64',
    cmd: 'curl -fsSL https://github.com/ibrahemid/writ/raw/main/install.sh | sh',
    alt: 'or .deb / AppImage →',
    altHref: '/writ/download/#linux',
  },
];
---
<section class="install" id="install">
  <hr class="rule-thick" />
  <div class="container install-inner">
    <header class="install-head">
      <span class="eyebrow">/* install */</span>
      <h2>One line. No installer wizard.</h2>
      <p class="install-sub">
        v0.1.0 · macOS 12+ · Windows 10+ · Linux (glibc 2.31+) ·
        <a href="/writ/download/">all binaries &amp; checksums →</a>
      </p>
    </header>

    <div class="osw" data-os-widget>
      <div class="osw-tabs" role="tablist" aria-label="Select operating system">
        {tabs.map((t, i) => (
          <button
            type="button"
            role="tab"
            id={`osw-tab-${t.id}`}
            aria-controls={`osw-panel-${t.id}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            tabindex={i === 0 ? 0 : -1}
            data-os={t.id}
            class={i === 0 ? 'is-active' : ''}
          >
            <span class="osw-label">{t.label}</span>
            <span class="osw-sub">{t.sub}</span>
          </button>
        ))}
      </div>

      {tabs.map((t, i) => (
        <div
          role="tabpanel"
          id={`osw-panel-${t.id}`}
          aria-labelledby={`osw-tab-${t.id}`}
          hidden={i !== 0}
          class="osw-panel"
          data-panel={t.id}
        >
          <div class="osw-prompt" aria-hidden="true">$</div>
          <code class="osw-cmd" data-cmd>{t.cmd}</code>
          <button type="button" class="osw-copy" data-copy aria-label={`Copy install command for ${t.label}`}>
            <span data-copy-default>copy</span>
            <span data-copy-done hidden>copied</span>
          </button>
          <a class="osw-alt" href={t.altHref}>{t.alt}</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .install { padding: var(--space-16) 0; }
  .install-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding-top: var(--space-12);
  }
  .install-head { display: flex; flex-direction: column; gap: var(--space-3); }
  .install-head h2 {
    margin: 0;
    font-size: var(--text-2xl);
    letter-spacing: -0.015em;
  }
  .install-sub {
    margin: 0;
    color: var(--muted-foreground);
    font-size: var(--text-sm);
  }
  .install-sub a { font-weight: 500; }

  .osw {
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    background: var(--syntax-bg);
    box-shadow: var(--card-shadow);
    overflow: hidden;
  }
  .osw-tabs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-bottom: 1px solid var(--border);
    background: color-mix(in oklab, var(--syntax-bg) 70%, var(--background));
  }
  .osw-tabs button {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    padding: var(--space-3) var(--space-5);
    background: transparent;
    border: 0;
    border-right: 1px solid var(--border);
    color: var(--muted-foreground);
    font-family: var(--font-mono-display);
    text-align: left;
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-out),
                background-color var(--duration-fast) var(--ease-out);
  }
  .osw-tabs button:last-child { border-right: 0; }
  .osw-tabs .osw-label {
    font-size: var(--text-base);
    font-weight: 600;
    color: inherit;
  }
  .osw-tabs .osw-sub {
    font-size: var(--text-xs);
    color: var(--ink-faint);
  }
  .osw-tabs button:hover { color: var(--foreground); background: color-mix(in oklab, var(--foreground) 3%, transparent); }
  .osw-tabs button.is-active {
    color: var(--accent);
    background: var(--syntax-bg);
    box-shadow: inset 0 -2px 0 0 var(--accent);
  }
  .osw-tabs button.is-active .osw-label { color: var(--accent); }

  .osw-panel {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-areas:
      'prompt cmd  copy'
      '.      alt  alt';
    gap: var(--space-3) var(--space-3);
    align-items: center;
    padding: var(--space-5) var(--space-5);
    font-family: var(--font-mono-display);
    color: var(--syntax-fg);
  }
  .osw-panel[hidden] { display: none; }
  .osw-prompt { grid-area: prompt; color: var(--accent); font-weight: 600; }
  .osw-cmd {
    grid-area: cmd;
    font-size: var(--text-md);
    color: var(--syntax-fg);
    overflow-x: auto;
    white-space: nowrap;
  }
  .osw-copy {
    grid-area: copy;
    background: transparent;
    color: var(--muted-foreground);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: 6px 12px;
    font-family: var(--font-mono-display);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
  }
  .osw-copy:hover { color: var(--accent); border-color: color-mix(in oklab, var(--accent) 50%, var(--border-strong)); }
  .osw-alt {
    grid-area: alt;
    color: var(--ink-faint);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
  }
  .osw-alt:hover { color: var(--accent); }

  @media (max-width: 640px) {
    .osw-tabs { grid-template-columns: 1fr; }
    .osw-tabs button { border-right: 0; border-bottom: 1px solid var(--border); }
    .osw-tabs button:last-child { border-bottom: 0; }
    .osw-panel { grid-template-columns: auto 1fr; grid-template-areas: 'prompt cmd' 'copy copy' 'alt alt'; }
  }
</style>

<script>
  import './Install.client.ts';
</script>
