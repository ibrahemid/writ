---
const groups = [
  {
    title: 'Summon',
    items: [
      { keys: ['Cmd', 'Shift', 'Space'], action: 'Toggle Writ (global)' },
    ],
  },
  {
    title: 'Tabs',
    items: [
      { keys: ['Cmd', 'T'], action: 'New tab' },
      { keys: ['Cmd', 'W'], action: 'Close tab' },
      { keys: ['Cmd', '['], action: 'Previous tab' },
      { keys: ['Cmd', ']'], action: 'Next tab' },
      { keys: ['Double-click'], action: 'Rename tab' },
    ],
  },
  {
    title: 'Workspace',
    items: [
      { keys: ['Cmd', 'S', 'S'], action: 'Toggle sidebar (double-tap)' },
      { keys: ['Shift', 'Shift'], action: 'Command palette' },
    ],
  },
];
---

<section class="section" id="shortcuts" aria-labelledby="shortcuts-heading">
  <div class="container">
    <header class="section-head">
      <p class="eyebrow">Shortcuts</p>
      <h2 id="shortcuts-heading">Keyboard, not menus</h2>
      <p class="lede">
        Every action has a keystroke. Muscle memory beats a mouse every time.
      </p>
    </header>

    <div class="sc-grid">
      {groups.map((g) => (
        <article class="sc-group">
          <h3 class="sc-group-title">{g.title}</h3>
          <ul class="sc-list" role="list">
            {g.items.map((s) => (
              <li>
                <span class="sc-keys" aria-hidden="true">
                  {s.keys.map((k, i) => (
                    <>
                      <kbd>{k}</kbd>
                      {i < s.keys.length - 1 && <span class="sc-plus">+</span>}
                    </>
                  ))}
                </span>
                <span class="sc-action">{s.action}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .sc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }
  .sc-group {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--card-shadow);
    padding: 1.25rem 1.25rem 0.6rem;
  }
  .sc-group-title {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--muted-foreground);
    margin: 0 0 0.75rem;
    font-weight: 500;
  }
  .sc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .sc-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--border);
  }
  .sc-list li:last-child {
    border-bottom: none;
  }
  .sc-keys {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .sc-plus {
    color: var(--muted-foreground);
    font-size: 0.72rem;
  }
  .sc-action {
    color: var(--muted-foreground);
    font-size: 0.9rem;
    text-align: right;
  }
</style>
