---
const claims = [
  {
    id: 'editor',
    n: '01',
    title: 'A real editor, not a textarea.',
    body: 'CodeMirror 6 underneath. Syntax highlighting on .rs, .ts, .py, .md. Browser-style tabs across buffers. The editor your terminal already trained you to expect.',
    shot: '/writ/shots/code-editor.png',
    alt: 'Writ editor showing a Rust file with syntax highlighting, line numbers, and three open tabs.',
  },
  {
    id: 'search',
    n: '02',
    title: 'Search every buffer at once.',
    body: 'Sidebar opens with the same keystroke you closed it. Full-text search across every tab you have ever opened, backed by SQLite FTS5. Open. Type. Jump.',
    shot: '/writ/shots/sidebar-tabs.png',
    alt: 'Writ sidebar listing recent buffers with a full-text search input at the top.',
  },
  {
    id: 'palette',
    n: '03',
    title: 'Command palette runs the whole app.',
    body: 'New tab, switch tab, rename, export, toggle theme. ⌘K opens it from anywhere. No menu hunting. No mouse.',
    shot: '/writ/shots/command-palette.png',
    alt: 'Writ command palette overlay listing actions like “New tab”, “Switch tab”, and “Toggle theme”.',
  },
];
---
<section class="claims" id="features">
  <hr class="rule-thick" />
  <div class="container claims-head">
    <span class="eyebrow">/* what it is */</span>
    <h2>Three things, done well.</h2>
  </div>

  {claims.map((c, i) => (
    <article class={`row ${i % 2 === 1 ? 'row-rev' : ''}`} id={c.id}>
      <div class="container row-grid">
        <div class="row-text">
          <span class="row-num">{c.n}</span>
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </div>
        <div class="row-shot">
          <div class="shot-frame">
            <img
              src={c.shot}
              alt={c.alt}
              width="1628"
              height={c.id === 'editor' ? 1292 : 1166}
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
      {i < claims.length - 1 && <hr class="rule" />}
    </article>
  ))}
</section>

<style>
  .claims { padding-top: var(--space-12); }
  .claims-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-top: var(--space-12);
    padding-bottom: var(--space-10);
  }
  .claims-head h2 {
    margin: 0;
    font-size: var(--text-2xl);
    letter-spacing: -0.02em;
  }
  .row { padding: var(--space-12) 0; }
  .row-grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: var(--space-12);
    align-items: center;
  }
  .row-rev .row-grid {
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
  }
  .row-rev .row-text { order: 2; }
  .row-rev .row-shot { order: 1; }

  .row-text { display: flex; flex-direction: column; gap: var(--space-3); }
  .row-num {
    font-family: var(--font-mono-display);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
  }
  .row-text h3 {
    margin: 0;
    font-size: var(--text-xl);
    letter-spacing: -0.015em;
    color: var(--foreground);
    max-width: 18ch;
  }
  .row-text p {
    margin: 0;
    color: var(--muted-foreground);
    font-size: var(--text-base);
    line-height: 1.55;
    max-width: 42ch;
  }

  .shot-frame {
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--card);
    box-shadow: var(--card-shadow);
  }
  .shot-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 800px) {
    .row-grid, .row-rev .row-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .row-rev .row-text { order: 1; }
    .row-rev .row-shot { order: 2; }
    .row { padding: var(--space-8) 0; }
  }
</style>
