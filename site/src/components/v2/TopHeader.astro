---
const repo = 'https://github.com/ibrahemid/writ';
---
<header class="v2-header">
  <div class="ticker" data-collapsed="false" aria-hidden="true">
    <div class="track">
      <span class="ti lv"><i class="dd"></i> opening <b>report.md</b> · code · configs · logs · hex</span>
      <span class="ti"><i class="dd"></i> <b>full-text</b> search</span>
      <span class="ti"><i class="dd"></i> <b>⇧⇧</b> command palette</span>
      <span class="ti"><i class="dd"></i> renders <b>md</b> · html · mermaid · katex</span>
      <span class="ti"><i class="dd"></i> tokens counted <b>live</b></span>
      <span class="ti"><i class="dd"></i> works <b>offline</b></span>
      <span class="ti lv"><i class="dd"></i> opening <b>report.md</b> · code · configs · logs · hex</span>
      <span class="ti"><i class="dd"></i> <b>full-text</b> search</span>
      <span class="ti"><i class="dd"></i> <b>⇧⇧</b> command palette</span>
      <span class="ti"><i class="dd"></i> renders <b>md</b> · html · mermaid · katex</span>
      <span class="ti"><i class="dd"></i> tokens counted <b>live</b></span>
      <span class="ti"><i class="dd"></i> works <b>offline</b></span>
    </div>
  </div>
  <div style="max-width:1100px; margin:0 auto; padding:0 22px; height:54px; display:flex; align-items:center; gap:16px">
    <a href="#top" style="display:inline-flex; align-items:baseline; font-family:var(--font-display); font-weight:800; font-size:19px; letter-spacing:-.045em; color:var(--foreground); flex:none">Writ<span style="color:var(--accent)">.</span></a>
    <nav class="topnav hide-sm" style="display:flex; gap:2px; margin-left:4px">
      <a href="#editor" style="font-family:var(--font-mono); font-size:12px; color:var(--muted); padding:7px 9px; border-radius:7px">Editor</a>
      <a href="#render" style="font-family:var(--font-mono); font-size:12px; color:var(--muted); padding:7px 9px; border-radius:7px">Render</a>
      <a href="#search" style="font-family:var(--font-mono); font-size:12px; color:var(--muted); padding:7px 9px; border-radius:7px">Search</a>
      <a href="#download" style="font-family:var(--font-mono); font-size:12px; color:var(--muted); padding:7px 9px; border-radius:7px">Download</a>
    </nav>
    <div style="margin-left:auto; display:flex; align-items:center; gap:10px; flex:none">
      <button class="theme-toggle" type="button" data-toggle-theme aria-label="Switch color theme">
        <svg class="ic ic-sun" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
        <svg class="ic ic-moon" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>
      <a href="#download" class="hide-sm v2-btn-primary" style="display:inline-flex; align-items:center; height:34px; padding:0 15px; border-radius:9px; background:var(--accent); color:var(--accent-foreground); font-weight:600; font-size:13.5px">Download</a>
    </div>
  </div>
</header>

<script>
  (function () {
    const root = document.documentElement;
    const toggle = document.querySelector('[data-toggle-theme]');

    function syncTheme() {
      const t = root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
      if (toggle) {
        toggle.setAttribute(
          'aria-label',
          t === 'dark' ? 'Switch to light theme' : 'Switch to dark theme',
        );
      }
    }
    if (toggle) {
      toggle.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        try { localStorage.setItem('writ:theme', next); } catch (_) {}
        syncTheme();
        document.dispatchEvent(new CustomEvent('writ:theme', { detail: { theme: next } }));
      });
    }
    syncTheme();

    // Ticker collapses on first scroll for a cleaner header.
    const ticker = document.querySelector('.ticker');
    let collapsed = false;
    const onScroll = () => {
      const next = (window.scrollY || window.pageYOffset || 0) > 56;
      if (next === collapsed) return;
      collapsed = next;
      if (ticker) ticker.setAttribute('data-collapsed', String(next));
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
