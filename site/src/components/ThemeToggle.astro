---
---
<div class="ttg" role="group" aria-label="Theme">
  <button type="button" data-set="light" aria-pressed="true">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" aria-hidden="true">
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4 7 17M17 7l1.4-1.4"></path>
    </svg>
    <span>light</span>
  </button>
  <button type="button" data-set="dark" aria-pressed="false">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" aria-hidden="true">
      <path d="M20 14.5A8 8 0 0 1 9.5 4 8 8 0 1 0 20 14.5z"></path>
    </svg>
    <span>dark</span>
  </button>
</div>

<style>
  .ttg {
    display: inline-flex;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    padding: 2px;
    background: var(--card);
  }
  .ttg button {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    background: transparent;
    border: 0;
    border-radius: var(--radius-sm);
    color: var(--muted-foreground);
    font-family: var(--font-mono-display);
    font-size: var(--text-xs);
    font-weight: 500;
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out),
                color var(--duration-fast) var(--ease-out);
  }
  .ttg button[aria-pressed='true'] {
    background: var(--background);
    color: var(--accent);
  }
  .ttg button:hover { color: var(--foreground); }
  .ttg button[aria-pressed='true']:hover { color: var(--accent); }
  .ttg svg { display: block; }
</style>

<script>
  const root = document.documentElement;
  const buttons = document.querySelectorAll<HTMLButtonElement>('.ttg button');

  function apply(theme: 'light' | 'dark') {
    root.setAttribute('data-theme', theme);
    try { localStorage.setItem('writ:theme', theme); } catch {}
    buttons.forEach((b) => {
      b.setAttribute('aria-pressed', String(b.dataset.set === theme));
    });
  }

  const current = (root.getAttribute('data-theme') as 'light' | 'dark') || 'light';
  buttons.forEach((b) => {
    b.setAttribute('aria-pressed', String(b.dataset.set === current));
    b.addEventListener('click', () => apply(b.dataset.set as 'light' | 'dark'));
  });
</script>
