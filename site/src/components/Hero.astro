---
import HeroDemo from './HeroDemo.tsx';
---
<section class="hero">
  <div class="container hero-inner">
    <p class="eyebrow">
      <b>writ</b>
      <span aria-hidden="true">/rɪt/</span>
      <span class="sep">·</span>
      <span>v0.1.0</span>
    </p>

    <h1 class="hero-h1">
      <span class="editorial">A scratchpad</span>
      <span class="hero-h1-line2">always one keypress away.</span>
    </h1>

    <p class="hero-keys" aria-label="Global hotkey">
      <span><kbd>⌘</kbd> <kbd>⇧</kbd> <kbd>Space</kbd></span>
      <span class="hero-keys-os">macOS</span>
      <span class="hero-keys-sep" aria-hidden="true">·</span>
      <span><kbd>Ctrl</kbd> <kbd>⇧</kbd> <kbd>Space</kbd></span>
      <span class="hero-keys-os">Windows · Linux</span>
    </p>

    <div class="hero-cta">
      <a class="bracket-link is-primary" href="/writ/download/">download for macOS</a>
      <a class="bracket-link" href="https://github.com/ibrahemid/writ" rel="noopener" target="_blank">github</a>
      <span class="hero-cta-meta">no account · no telemetry · MIT</span>
    </div>

    <div class="hero-demo">
      <HeroDemo client:visible />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-16) 0 var(--space-12);
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .eyebrow .sep {
    color: var(--rule);
    padding: 0 0.15em;
  }
  .hero-h1 {
    margin: var(--space-2) 0 0;
    font-family: var(--font-mono-display);
    font-weight: 500;
    font-size: var(--text-display);
    line-height: 1.05;
    letter-spacing: -0.025em;
    max-width: 22ch;
    color: var(--foreground);
  }
  .hero-h1 .editorial {
    color: var(--accent);
    font-size: 1.08em;
    margin-right: 0.18em;
  }
  .hero-h1-line2 {
    display: block;
  }

  .hero-keys {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    margin: 0;
    color: var(--muted-foreground);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
  }
  .hero-keys kbd { font-size: 0.85em; }
  .hero-keys-os {
    color: var(--ink-faint);
    text-transform: lowercase;
    letter-spacing: 0;
    font-size: 0.95em;
  }
  .hero-keys-sep { color: var(--rule); }

  .hero-cta {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-6);
    margin-top: var(--space-2);
  }
  .hero-cta-meta {
    color: var(--ink-faint);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
  }

  .hero-demo {
    margin-top: var(--space-8);
  }

  @media (max-width: 640px) {
    .hero-h1 { font-size: 2.4rem; }
    .hero-h1 .editorial { font-size: 1.05em; }
  }
</style>
