---
import LiveEditor from '../islands/LiveEditor';
---
<!-- dynamic-island live status (static markup; Phase H wires island behavior) -->
<div class="island tuck" id="island" role="status" aria-label="Writ live status: rendering report.md, FTS index 12,841 notes, cold start target under 200 ms, no account, no telemetry">
  <div class="state" aria-hidden="true"></div>
  <!-- .full is a decorative hover enhancement; aria-hidden keeps it out of the a11y tree -->
  <div class="full" aria-hidden="true">
    <div class="fh"><span class="live"></span>live · writ</div>
    <div class="fr"><span class="gl"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3h9l5 5v13H6z" fill="none" stroke="currentColor" stroke-width="2"/><path d="M14 3v6h6" fill="none" stroke="currentColor" stroke-width="2"/></svg></span>rendering <b>report.md</b> <span class="mut">· 4 Mermaid · 2 KaTeX</span></div>
    <div class="fr"><span class="gl"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2.2"/><path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2.2"/></svg></span>FTS index <span class="mut">·</span> <b>12,841</b> notes</div>
    <div class="fr"><span class="gl"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"/><path d="M12 7v5l3 2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span>cold start <span class="mut">target</span> <b>&lt;200 ms</b></div>
    <div class="fr"><span class="gl"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h6l2 2h10v11H3z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg></span>watch-inbox <span class="mut">·</span> <b>diff.patch</b> opened</div>
    <div class="fr"><span class="gl"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 5 6v6c0 4 3 7 7 8 4-1 7-4 7-8V6Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg></span><b>no account</b> <span class="mut">·</span> no telemetry</div>
    <div class="fr"><span class="gl"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 8l3 4-3 4M11 16h8" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>piped <b>claude -p … | writ -</b></div>
  </div>
</div>

<section class="desktop">
  <div class="hero">
    <!-- repositioned headline, reworded, no kicker label -->
    <div class="lede">
      <h1 class="disp">Read what your<br>agent wrote.<br><span class="ac">Keep what you dump.</span></h1>
      <p>One macOS surface for everything around the code. <b>Renders Markdown, HTML, Mermaid and KaTeX offline</b>, then keeps every scratch you make, searchable.</p>
      <div class="actions">
        <a class="btn btn-primary" href="#get">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.4 12.9c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.8-1.8-3.4-1.8-1.4-.1-2.8.9-3.5.9s-1.8-.8-3-.8c-1.5 0-2.9.9-3.7 2.3-1.6 2.7-.4 6.8 1.1 9 .7 1.1 1.6 2.3 2.8 2.3 1.1 0 1.5-.7 2.9-.7s1.7.7 2.9.7 2-1.1 2.7-2.1c.8-1.2 1.2-2.4 1.2-2.4s-2.3-.9-2.3-3.6Z"/></svg>
          Download for macOS
        </a>
        <a class="btn btn-ghost" href="#get">free core · no account</a>
      </div>
    </div>

    <!-- the cluster: multiple screens, each with an overlay label -->
    <div class="cluster">
      <!-- main: rendered output -->
      <div class="screen s-main">
        <span class="olabel"><span class="n">01</span> renders agent output</span>
        <div class="win-bar">
          <div class="lights" aria-hidden="true"><i class="c"></i><i class="m"></i><i class="x"></i></div>
          <div class="win-tabs"><span class="tab active"><span class="dot"></span>report.md</span><span class="tab"><span class="dot"></span>diff.patch</span><span class="tab"><span class="dot"></span>schema.sql</span></div>
        </div>
        <div class="win-body">
          <aside class="win-side">
            <div class="side-h">Watch inbox</div>
            <div class="side-row on"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16v16H4z"/><path d="M9 9h6M9 13h6"/></svg>report.md</div>
            <div class="side-row"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 3v18M18 3v18"/></svg>diff.patch</div>
            <div class="side-row"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/></svg>plan.md</div>
          </aside>
          <div class="win-main">
            <div class="split">
              <!-- live-editor mount: LiveEditor island hydrates on visibility;
                   static srchint hint stays until first keystroke -->
              <div id="live-editor-mount" class="pane src">
                <span class="srchint" id="srchint">edit me ↹</span>
                <LiveEditor client:visible />
              </div>
              <div class="pane rnd"><div class="doc" id="doc">
                <span class="tag">agent output · rendered</span>
                <h2>Retrieval audit</h2>
                <p>Recall improved after the <code>rerank</code> stage, mostly on long-tail queries.</p>
                <blockquote>Hit-rate is bounded by the index recall ceiling.</blockquote>
                <h3>Flow</h3>
                <div class="mermaid"><svg viewBox="0 0 420 60" width="100%" height="60" role="img" aria-label="Query to Embed to Retrieve to Rerank">
                  <g class="edge"><path d="M84 30 H110"/></g><g class="edge"><path d="M188 30 H214"/></g><g class="edge"><path d="M300 30 H326"/></g>
                  <polygon class="arrow" points="110,30 103,26 103,34"/><polygon class="arrow" points="214,30 207,26 207,34"/><polygon class="arrow" points="326,30 319,26 319,34"/>
                  <g class="node"><rect x="6" y="13" width="78" height="34" rx="8"/><text x="45" y="34" text-anchor="middle">Query</text></g>
                  <g class="node"><rect x="111" y="13" width="77" height="34" rx="8"/><text x="149" y="34" text-anchor="middle">Embed</text></g>
                  <g class="node"><rect x="215" y="13" width="85" height="34" rx="8"/><text x="257" y="34" text-anchor="middle">Retrieve</text></g>
                  <g class="node alt"><rect x="327" y="13" width="88" height="34" rx="8"/><text x="371" y="34" text-anchor="middle">Rerank</text></g>
                </svg></div>
                <h3>Precision</h3>
                <div class="katex"><i>P</i> <span style="margin:0 .2em">=</span> <span class="frac"><span class="t"><i>tp</i></span><span class="b"><i>tp</i> + <i>fp</i></span></span></div>
              </div></div>
            </div>
            <div class="win-status"><span class="save"><i></i>Saved</span><span>Markdown</span><span>UTF-8</span><span class="sp"></span><span class="tnum" id="cc">1,284 tokens</span><span class="tnum" id="lc">Ln 12, Col 1</span></div>
          </div>
        </div>
      </div>

      <!-- search -->
      <div class="screen s-search">
        <span class="olabel"><span class="n">02</span> search every note</span>
        <div class="win-bar"><div class="lights" aria-hidden="true"><i class="c"></i><i class="m"></i><i class="x"></i></div><div class="win-tabs"><span class="tab active" style="font-size:10.5px">FTS5</span></div></div>
        <div class="search-in"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>rerank ceiling</div>
        <div class="sr on"><span class="file">report.md</span><span class="hit">index <b>rerank ceiling</b></span><span class="n">L5</span></div>
        <div class="sr"><span class="file">api-notes.md</span><span class="hit">raise <b>rerank</b> top-k</span><span class="n">L22</span></div>
        <div class="sr"><span class="file">retro-q2.md</span><span class="hit"><b>ceiling</b> recall index</span><span class="n">L8</span></div>
        <div class="win-status"><span class="tnum">3 of 12,841 notes</span><span class="sp"></span><span>0.6 ms</span></div>
      </div>

      <!-- prompt -->
      <div class="screen s-prompt">
        <span class="olabel"><span class="n">03</span> prompt workbench</span>
        <div class="win-bar"><div class="lights" aria-hidden="true"><i class="c"></i><i class="m"></i><i class="x"></i></div><div class="win-tabs"><span class="tab active" style="font-size:10.5px">review.prompt</span></div></div>
        <div class="pw"><span class="cm"># review.prompt</span>
Review <span class="v">&#123;&#123;file&#125;&#125;</span> for
<span class="v">&#123;&#123;concern&#125;&#125;</span>. Be terse.</div>
        <div class="pwbar"><span>3 variables</span><span class="tnum">≈ 38 tok</span><span class="cp">copy as prompt</span></div>
      </div>

      <!-- watch -->
      <div class="screen s-watch">
        <span class="olabel"><span class="n">04</span> watch inbox</span>
        <div class="win-bar"><div class="lights" aria-hidden="true"><i class="c"></i><i class="m"></i><i class="x"></i></div><div class="win-tabs"><span class="tab active" style="font-size:10.5px">~/agent-out</span></div></div>
        <div class="frow on"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16v16H4z"/></svg><span class="nm">report.md</span><span class="sz">8 KB</span></div>
        <div class="frow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 3v18M18 3v18"/></svg><span class="nm">diff.patch</span><span class="sz">2 KB</span></div>
        <div class="frow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/></svg><span class="nm">plan.md</span><span class="sz">5 KB</span></div>
      </div>
    </div>

    <div class="scrollcue" aria-hidden="true"><span class="ar">↓</span> scroll · one reflex at a time</div>
  </div>
</section>

<script>
  (function () {
    const island = document.getElementById('island');
    if (!island) return;
    const stateEl = island.querySelector<HTMLElement>('.state');
    if (!stateEl) return;
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

    const GL: Record<string, string> = {
      doc: '<path d="M6 3h9l5 5v13H6z" fill="none" stroke="currentColor" stroke-width="2"/><path d="M14 3v6h6" fill="none" stroke="currentColor" stroke-width="2"/>',
      search: '<circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2.2"/><path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2.2"/>',
      clock: '<circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"/><path d="M12 7v5l3 2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
      watch: '<path d="M3 6h6l2 2h10v11H3z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>',
      shield: '<path d="M12 3 5 6v6c0 4 3 7 7 8 4-1 7-4 7-8V6Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>',
      pipe: '<path d="M5 8l3 4-3 4M11 16h8" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>',
    };
    const svg = (n: string) =>
      '<span class="gl"><svg viewBox="0 0 24 24" aria-hidden="true">' + GL[n] + '</svg></span>';

    const STATES = [
      { g: 'doc',    t: 'rendering <b>report.md</b> <span class="mut">· 4 Mermaid · 2 KaTeX</span>' },
      { g: 'search', t: 'FTS index <span class="mut">·</span> <b>12,841</b> notes' },
      { g: 'clock',  t: 'cold start <span class="mut">target</span> <b>&lt;200 ms</b>' },
      { g: 'watch',  t: 'watch-inbox <span class="mut">·</span> <b>diff.patch</b> opened' },
      { g: 'shield', t: '<b>no account</b> <span class="mut">·</span> no telemetry' },
      { g: 'pipe',   t: 'piped <b>claude -p … | writ -</b>' },
    ];

    const paint = (k: number) => {
      const s = STATES[k];
      if (!s) return;
      stateEl!.innerHTML = svg(s.g) + '<span class="txt">' + s.t + '</span>';
    };

    if (reduce) {
      // Static: show first state, no timer, no width animation
      paint(0);
      return;
    }

    // Measure natural width per state
    const meas = document.createElement('span');
    meas.style.cssText =
      'position:absolute;visibility:hidden;left:0;top:0;display:inline-flex;align-items:center;gap:9px;white-space:nowrap;font-family:var(--mono);font-size:11.5px;line-height:1';
    island.appendChild(meas);
    let widths: number[] = [];
    const measureAll = () => {
      widths = STATES.map(s => {
        meas.innerHTML = svg(s.g) + '<span>' + s.t + '</span>';
        return Math.ceil(meas.getBoundingClientRect().width) + 36;
      });
    };
    let i = 0;
    paint(0);
    measureAll();
    island.style.width = widths[0] + 'px';

    if (document.fonts?.ready) {
      document.fonts.ready.then(() => {
        measureAll();
        if (!island.classList.contains('open')) island.style.width = widths[i] + 'px';
      });
    }

    let timer: ReturnType<typeof setInterval> | null = null;
    let paused = false;

    const stop = () => { if (timer) { clearInterval(timer); timer = null; } };
    const start = () => {
      if (paused) return;
      stop();
      timer = setInterval(next, 2900);
    };

    function next() {
      const ni = (i + 1) % STATES.length;
      stateEl!.classList.add('out');
      setTimeout(() => {
        i = ni;
        paint(i);
        island!.style.width = widths[i] + 'px';
        stateEl!.classList.remove('out');
        stateEl!.classList.add('in-down');
        requestAnimationFrame(() => requestAnimationFrame(() => stateEl!.classList.remove('in-down')));
      }, 240);
    }

    island.addEventListener('mouseenter', () => {
      paused = true; stop();
      island.style.width = '';
      island.classList.add('open');
    });
    island.addEventListener('mouseleave', () => {
      paused = false;
      island.classList.remove('open');
      island.style.width = widths[i] + 'px';
      start();
    });

    start();

    window.addEventListener('resize', () => {
      measureAll();
      if (!island.classList.contains('open')) island.style.width = widths[i] + 'px';
    });

    // Tuck once the hero has scrolled past
    const desktop = document.querySelector<HTMLElement>('.desktop');
    const checkVis = () => {
      const hide = !!desktop && desktop.getBoundingClientRect().bottom < 150;
      if (hide === island.classList.contains('tuck')) return;
      island.classList.toggle('tuck', hide);
      if (hide) { paused = true; stop(); island.classList.remove('open'); island.style.width = widths[i] + 'px'; }
      else if (!island.matches(':hover')) { paused = false; start(); }
    };
    window.addEventListener('scroll', checkVis, { passive: true });
    checkVis();
  })();
</script>
