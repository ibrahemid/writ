---
import ThemeToggle from './ThemeToggle.astro';
---
<header class="hdr">
  <div class="container hdr-inner">
    <a href="/writ/" class="hdr-brand" aria-label="Writ — home">
      <img src="/writ/brand/icon-32.png" alt="" width="22" height="22" />
      <span class="hdr-wordmark">writ</span>
      <span class="hdr-version" aria-hidden="true">v0.1.0</span>
    </a>

    <nav class="hdr-nav" aria-label="Primary">
      <a href="/writ/download/">download</a>
      <a href="/writ/changelog/">changelog</a>
      <a href="/writ/privacy/">privacy</a>
      <a href="https://github.com/ibrahemid/writ" rel="noopener" target="_blank">github</a>
    </nav>

    <ThemeToggle />
  </div>
  <hr class="rule" />
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--background) 88%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .hdr-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-6);
    height: 56px;
  }
  .hdr-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--foreground);
    font-family: var(--font-mono-display);
    font-weight: 600;
    font-size: var(--text-base);
  }
  .hdr-brand:hover { color: var(--foreground); }
  .hdr-brand img { display: block; border-radius: 5px; }
  .hdr-wordmark { letter-spacing: -0.01em; }
  .hdr-version {
    color: var(--ink-faint);
    font-weight: 400;
    font-size: var(--text-xs);
    padding-left: var(--space-2);
    border-left: 1px solid var(--rule);
    margin-left: var(--space-1);
  }
  .hdr-nav {
    display: inline-flex;
    gap: var(--space-5);
    justify-content: center;
    font-size: var(--text-sm);
  }
  .hdr-nav a {
    color: var(--muted-foreground);
    font-weight: 500;
  }
  .hdr-nav a:hover { color: var(--foreground); }

  @media (max-width: 720px) {
    .hdr-nav { display: none; }
    .hdr-inner { grid-template-columns: auto 1fr auto; }
  }
</style>
