<header class="nav" role="banner">
  <a class="brand" href={`${import.meta.env.BASE_URL}`} aria-label="Writ home">Writ<span class="ac">.</span><span class="tagline">render surface</span></a>
  <nav class="hnav">
    <a href="#compare"><span class="n">01</span> Compare</a>
    <a href="#get" class="persist"><span class="n">02</span> Download</a>
    <a href="https://github.com/ibrahemid/writ" rel="noopener noreferrer" target="_blank"><span class="n">03</span> GitHub</a>
  </nav>
  <div class="hright">
    <button class="tt" id="themeBtn" aria-label="Toggle dark mode" type="button">
      <svg class="mb-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      <svg class="mb-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1111.2 3 7 7 0 0021 12.8z"/></svg>
    </button>
    <a class="hdl" href="#get">Download ↘</a>
  </div>
</header>

<script>
  (function () {
    const btn = document.getElementById('themeBtn');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try { localStorage.setItem('writ:theme', next); } catch (_) {}
      document.dispatchEvent(new CustomEvent('writ:theme', { detail: { theme: next } }));
    });
  })();
</script>
