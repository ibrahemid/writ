---

const rows = [
  { label: 'Opens in', writ: '< 80ms', txt: 'OS-dependent', obs: '1–3s', notion: '2–8s' },
  { label: 'Local-only, offline', writ: 'yes', txt: 'yes', obs: 'yes', notion: 'partial' },
  { label: 'Account required', writ: 'no', txt: 'no', obs: 'no', notion: 'yes' },
  { label: 'Global hotkey summon', writ: 'yes', txt: 'no', obs: 'third-party', notion: 'no' },
  { label: 'Autosave per keystroke', writ: 'yes', txt: 'no', obs: 'yes', notion: 'yes' },
  { label: 'Full-text search across history', writ: 'yes', txt: 'via OS', obs: 'yes', notion: 'yes' },
  { label: 'File footprint', writ: '~15MB', txt: 'OS native', obs: '~200MB', notion: '~300MB + web' },
  { label: 'Telemetry', writ: 'none', txt: 'none', obs: 'optional', notion: 'default on' },
  { label: 'Price', writ: 'free · MIT', txt: 'free', obs: 'free', notion: 'freemium' },
];

function mark(v: string) {
  if (v === 'yes') return { kind: 'yes', label: 'Yes' };
  if (v === 'no') return { kind: 'no', label: 'No' };
  return { kind: 'neutral', label: v };
}
---

<section class="section" id="compare" aria-labelledby="compare-heading">
  <div class="container">
    <header class="section-head">
      <p class="eyebrow">Compare</p>
      <h2 id="compare-heading">Positioned in the missing middle</h2>
      <p class="lede">
        Plain text files are fast but forgetful. Obsidian and Notion are powerful but heavy.
        Writ sits between: instant, keyboard-first, local-only.
      </p>
    </header>

    <div class="cmp-wrap reveal">
      <table class="cmp-table">
          <thead>
            <tr>
              <th scope="col"><span class="visually-hidden">Capability</span></th>
              <th scope="col" class="cmp-h cmp-h--writ">
                <span class="cmp-dot cmp-dot--writ" aria-hidden="true"></span>
                Writ
              </th>
              <th scope="col" class="cmp-h">Plain .txt</th>
              <th scope="col" class="cmp-h">Obsidian</th>
              <th scope="col" class="cmp-h">Notion</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => {
              const w = mark(row.writ);
              const t = mark(row.txt);
              const o = mark(row.obs);
              const n = mark(row.notion);
              return (
                <tr>
                  <th scope="row" class="cmp-label">{row.label}</th>
                  <td class={`cmp-cell cmp-cell--writ cmp-cell--${w.kind}`}>{w.label}</td>
                  <td class={`cmp-cell cmp-cell--${t.kind}`}>{t.label}</td>
                  <td class={`cmp-cell cmp-cell--${o.kind}`}>{o.label}</td>
                  <td class={`cmp-cell cmp-cell--${n.kind}`}>{n.label}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

    <p class="cmp-note muted">
      Snapshot. Obsidian and Notion are great at what they do. Writ does something else:
      it gets out of the way.
    </p>
  </div>
</section>

<style>
  .cmp-wrap {
    overflow-x: auto;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--card-shadow);
  }
  .cmp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
    min-width: 640px;
  }
  .cmp-table th,
  .cmp-table td {
    padding: 0.85rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }
  .cmp-table tbody tr:last-child th,
  .cmp-table tbody tr:last-child td {
    border-bottom: 0;
  }
  .cmp-table thead th {
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--muted-foreground);
    font-weight: 500;
    background: color-mix(in oklab, var(--card) 88%, var(--background));
  }
  .cmp-h {
    white-space: nowrap;
  }
  .cmp-h--writ {
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .cmp-dot--writ {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .cmp-label {
    font-weight: 500;
    color: var(--foreground);
  }
  .cmp-cell {
    color: var(--muted-foreground);
  }
  .cmp-cell--writ {
    color: var(--foreground);
    background: color-mix(in oklab, var(--accent) 6%, transparent);
    position: relative;
  }
  .cmp-cell--yes {
    color: var(--success);
    font-weight: 500;
  }
  .cmp-cell--no {
    color: var(--muted-foreground);
    opacity: 0.7;
  }
  .cmp-cell--writ.cmp-cell--yes {
    color: var(--accent);
  }
  .cmp-table tbody tr:hover {
    background: var(--muted);
  }
  .cmp-note {
    text-align: center;
    margin: 1rem 0 0;
    font-size: 0.85rem;
  }
</style>
