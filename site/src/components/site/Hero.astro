        <span class="hs-fc-core">
          <svg class="hs-fc-face" viewBox="0 0 10 6" fill="none"><path d="M1.4 1.9 4 3.7M8.6 1.9 6 3.7" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/></svg>
        </span>
