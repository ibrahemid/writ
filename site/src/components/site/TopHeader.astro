---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<header class="v2-header">
  <div class="lens" aria-hidden="true">
    <div class="lens-inner">
      <div class="lens-track"></div>
    </div>
  </div>
  <div class="ticker" data-collapsed="false" aria-hidden="true">
    <div class="track">
      <span class="ti lv"><i class="dd"></i> <b>writ notes.md</b> opens from your terminal</span>
      <span class="ti"><i class="dd"></i> a folder opens as a <b>workspace</b></span>
      <span class="ti"><i class="dd"></i> default opener for <b>.md</b> · .log · .toml</span>
      <span class="ti"><i class="dd"></i> prompt <b>variables</b>, filled inline</span>
      <span class="ti"><i class="dd"></i> editable <b>themes</b> · rebindable shortcuts</span>
      <span class="ti"><i class="dd"></i> reopen a closed tab <b>⌘⇧T</b></span>
      <span class="ti lv"><i class="dd"></i> <b>writ notes.md</b> opens from your terminal</span>
      <span class="ti"><i class="dd"></i> a folder opens as a <b>workspace</b></span>
      <span class="ti"><i class="dd"></i> default opener for <b>.md</b> · .log · .toml</span>
      <span class="ti"><i class="dd"></i> prompt <b>variables</b>, filled inline</span>
      <span class="ti"><i class="dd"></i> editable <b>themes</b> · rebindable shortcuts</span>
      <span class="ti"><i class="dd"></i> reopen a closed tab <b>⌘⇧T</b></span>
    </div>
  </div>
  <div style="max-width:1100px; margin:0 auto; padding:0 22px; height:54px; display:flex; align-items:center; gap:16px">
    <a href={`${base}/`} style="display:inline-flex; align-items:baseline; font-family:var(--font-display); font-weight:800; font-size:19px; letter-spacing:-.045em; color:var(--foreground); flex:none">Writ<span style="color:var(--accent)">.</span></a>
    <nav class="topnav hide-sm" style="display:flex; gap:2px; margin-left:4px">
      <a href={`${base}/#editor`} style="font-family:var(--font-mono); font-size:12px; color:var(--muted); padding:7px 9px; border-radius:7px">Editor</a>
      <a href={`${base}/#render`} style="font-family:var(--font-mono); font-size:12px; color:var(--muted); padding:7px 9px; border-radius:7px">Render</a>
      <a href={`${base}/#search`} style="font-family:var(--font-mono); font-size:12px; color:var(--muted); padding:7px 9px; border-radius:7px">Search</a>
      <a href={`${base}/#shortcuts`} style="font-family:var(--font-mono); font-size:12px; color:var(--muted); padding:7px 9px; border-radius:7px">Shortcuts</a>
      <a href={`${base}/#themes`} style="font-family:var(--font-mono); font-size:12px; color:var(--muted); padding:7px 9px; border-radius:7px">Themes</a>
    </nav>
    <div style="margin-left:auto; display:flex; align-items:center; gap:10px; flex:none">
      <button class="theme-toggle" type="button" data-toggle-theme aria-label="Switch color theme">
        <svg class="ic ic-sun" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
        <svg class="ic ic-moon" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>
      <a href={`${base}/#download`} class="hide-sm v2-btn-primary" style="display:inline-flex; align-items:center; height:34px; padding:0 15px; border-radius:9px; background:var(--accent); color:var(--accent-foreground); font-weight:600; font-size:13.5px">Download</a>
    </div>
  </div>
</header>

<script>
  (function () {
    const root = document.documentElement;
    const toggle = document.querySelector('[data-toggle-theme]');

    function syncTheme() {
      const t = root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
      if (toggle) {
        toggle.setAttribute(
          'aria-label',
          t === 'dark' ? 'Switch to light theme' : 'Switch to dark theme',
        );
      }
    }
    if (toggle) {
      toggle.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        try { localStorage.setItem('writ:theme', next); } catch (_) {}
        syncTheme();
        document.dispatchEvent(new CustomEvent('writ:theme', { detail: { theme: next } }));
      });
    }
    syncTheme();

    // Ticker collapses on first scroll for a cleaner header.
    const ticker = document.querySelector('.ticker');
    let collapsed = false;
    const onScroll = () => {
      const next = (window.scrollY || window.pageYOffset || 0) > 56;
      if (next === collapsed) return;
      collapsed = next;
      if (ticker) ticker.setAttribute('data-collapsed', String(next));
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>

<script>
  (function () {
    const ticker = document.querySelector<HTMLElement>('.ticker');
    const track = ticker?.querySelector<HTMLElement>('.track');
    const lens = document.querySelector<HTMLElement>('.lens');
    const lensTrack = document.querySelector<HTMLElement>('.lens-track');
    if (!ticker || !track || !lens || !lensTrack) return;
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const SCALE = 1.5;
    const LENS_W = 150;
    let raf = 0;
    let mouseX = 0;
    let lensX = 0;
    let velocity = 0;
    let active = false;

    const frame = () => {
      const tickerRect = ticker.getBoundingClientRect();
      const target = mouseX - tickerRect.left - LENS_W / 2;
      const prev = lensX;
      lensX += (target - lensX) * 0.38;
      velocity = velocity * 0.82 + (lensX - prev) * 0.18;
      const squish = Math.min(1 + Math.abs(velocity) * 0.01, 1.12);
      lens.style.transform = `translate(${lensX}px, -50%) scaleX(${squish}) scaleY(${2 - squish})`;

      const m = new DOMMatrixReadOnly(getComputedStyle(track).transform);
      const contentX = mouseX - tickerRect.left - m.m41;
      lensTrack.style.transform = `translateX(${LENS_W / 2 - SCALE * contentX}px) scale(${SCALE})`;
      if (active) raf = requestAnimationFrame(frame);
    };

    ticker.addEventListener('pointerenter', (e) => {
      if (ticker.getAttribute('data-collapsed') === 'true') return;
      if (!lensTrack.childNodes.length) lensTrack.innerHTML = track.innerHTML;
      mouseX = e.clientX;
      lensX = mouseX - ticker.getBoundingClientRect().left - LENS_W / 2;
      active = true;
      lens.classList.add('on');
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(frame);
    });
    ticker.addEventListener('pointermove', (e) => {
      mouseX = e.clientX;
    });
    const stop = () => {
      active = false;
      lens.classList.remove('on');
      cancelAnimationFrame(raf);
    };
    ticker.addEventListener('pointerleave', stop);
    window.addEventListener('scroll', () => {
      if (ticker.getAttribute('data-collapsed') === 'true') stop();
    }, { passive: true });
  })();
</script>
