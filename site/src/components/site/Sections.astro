---
import Section from './Section.astro';
import release from '../../data/release.json';

interface KcCol {
  h: string;
  rows: { label: string; groups: string[][] }[];
}
interface PresetChip {
  name: string;
  polarity: string;
  surface: { background: string };
  foreground: { default: string };
  accent: { default: string };
  syntax: {
    keyword: string;
    string: string;
    comment: string;
    function: string;
    number: string;
    type: string;
    variable: string;
  };
}
interface Props {
  kcCols: readonly KcCol[];
  presets: readonly PresetChip[];
}
const { kcCols, presets } = Astro.props;

const repo = 'https://github.com/ibrahemid/writ';
const releasesUrl = repo + '/releases';
const published = release.published === true;
const notarized = release.notarized === true;
const sumsUrl = `${repo}/releases/download/${release.tag}/SHA256SUMS.txt`;

const oneliners = [
  { os: 'macOS', cmd: 'brew install --cask ibrahemid/writ/writ' },
  { os: 'Windows', cmd: 'winget install -e --id ibrahemid.Writ' },
  { os: 'Linux', cmd: 'curl -fsSL https://github.com/ibrahemid/writ/raw/main/install.sh | sh' },
];
---
<!-- WHY -->
<Section slug="why-writ">
  <p class="sec-lead">A text editor opens fast but shows raw text. An IDE renders everything but is slow to reach for. Writ is the fast middle.</p>
</Section>

<!-- RENDERS -->
<Section slug="renders" id="render">
  <h2 class="sec-h2">Four formats, drawn live.</h2>
  <p class="sec-p">Source, split, preview. In Markdown, lists continue on Enter and checkboxes toggle when clicked. Load one into the window:</p>
  <div class="trig-row">
    <button class="gtrig" type="button" data-cmd="loadFmt" data-arg="md"><span class="trig-g">#</span> Markdown</button>
    <button class="gtrig" type="button" data-cmd="loadFmt" data-arg="html"><span class="trig-g">&lt;/&gt;</span> HTML</button>
    <button class="gtrig" type="button" data-cmd="loadFmt" data-arg="mermaid"><span class="trig-g">A→B</span> Mermaid</button>
    <button class="gtrig" type="button" data-cmd="loadFmt" data-arg="math"><span class="trig-g">∑</span> KaTeX</button>
  </div>
</Section>

<!-- OPENS / COUNTS / FINDS -->
<Section slug="search" id="search">
  <h2 class="sec-h2">Open anything. Keep what matters.</h2>
  <div class="card-grid">
    <div class="card">
      <div class="card-k">opens anything</div>
      <h3 class="card-h">Every file, one window</h3>
      <p class="card-p">Code with syntax highlighting. Configs and logs as plain text. Binaries as hex. Large files without choking.</p>
      <button class="gtrig gtrig-sm" type="button" data-cmd="open" data-arg="icon-256.png">View a binary as hex →</button>
    </div>
    <div class="card">
      <div class="card-k">counts tokens</div>
      <h3 class="card-h">Know the cost before you paste</h3>
      <p class="card-p">A running token estimate in the status bar. Stay under the context window.</p>
      <button class="gtrig gtrig-sm" type="button" data-cmd="open" data-arg="gateway-week.log">Open a large log →</button>
    </div>
    <div class="card">
      <div class="card-k">stays findable</div>
      <h3 class="card-h">Nothing you dump gets lost</h3>
      <p class="card-p">Full-text index on disk. Search lands the matching line.</p>
      <button class="gtrig gtrig-sm" type="button" data-cmd="search" data-arg="settle">Search “settle” →</button>
    </div>
  </div>
</Section>

<!-- SHORTCUTS -->
<Section slug="shortcuts" id="shortcuts">
  <h2 class="sec-h2">Reach any command from the keyboard.</h2>
  <p class="sec-p">Double Shift opens the palette to search them all. These have a key of their own.</p>
  <div class="kc-cols">
    {kcCols.map((col) => (
      <div class="kc-col">
        <div class="kc-col-h">{col.h}</div>
        {col.rows.map((row) => (
          <div class="kc-row">
            <span class="kc-label">{row.label}</span>
            <span class="kc-keys">
              {row.groups.map((g, gi) => (
                <Fragment>
                  {gi > 0 && <span class="kc-sep">/</span>}
                  {g.map((k) => <kbd class="kc">{k}</kbd>)}
                </Fragment>
              ))}
            </span>
          </div>
        ))}
      </div>
    ))}
  </div>
  <p class="sec-note">Try them in the <a href="#editor">window above</a>.</p>
</Section>

<!-- SPELLING / REWRITE -->
<Section slug="text" id="text">
  <h2 class="sec-h2">Clean up the text, on your machine.</h2>
  <div class="card-grid card-grid-wide">
    <div class="card">
      <div class="card-k">spell check</div>
      <h3 class="card-h">Checks spelling locally</h3>
      <p class="card-p">Nothing leaves your machine. Likely misspellings get a wavy underline; code, URLs, and links stay clear. Fix them all at once or ignore a word. Off by default.</p>
      <div class="spell-demo">
        <div class="spell-body">
          the <span class="spell-err">settlment</span> worker reads<br />
          the bus and never <span class="spell-err">recieves</span> a <code class="spell-code">dup</code>
        </div>
        <div class="spell-status">
          <span>Ln 4, Col 12</span>
          <div class="spell-spacer"></div>
          <span class="spell-count">2 spelling</span>
          <div class="spell-menu">
            <span class="spell-mi spell-mi-on">Fix all (2)</span>
            <span class="spell-mi">Preview…</span>
            <span class="spell-mi">Turn off spelling</span>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-k">rewrite</div>
      <h3 class="card-h">Rewrite a selection, if you want it</h3>
      <p class="card-p">Proofread, rephrase, or polish selected text. Runs on a local model by default; bring your own key for a hosted provider and it stays in the OS keychain. Off until you turn it on, and text is sent only when you run a rewrite.</p>
      <div class="pill-row">
        <span class="pill">Proofread</span>
        <span class="pill">Rephrase</span>
        <span class="pill">Polish</span>
      </div>
      <p class="card-foot">Ollama local, or Groq · Gemini · DeepSeek · OpenRouter with your key</p>
    </div>
  </div>
</Section>

<!-- FROM A TERMINAL -->
<Section slug="terminal" id="terminal">
  <h2 class="sec-h2">When something else makes the file.</h2>
  <p class="sec-p">An agent writes a note, a script drops a log. Writ is where it opens, rendered and searchable.</p>
  <div class="term-grid">
    <div class="term">
      <div class="term-line"><span class="term-p">$</span> <span class="term-c">writ notes.md</span></div>
      <div class="term-line"><span class="term-p">$</span> <span class="term-c">pytest -q | writ --title run</span></div>
      <div class="term-line"><span class="term-cm"># already running in the background</span></div>
    </div>
    <div class="cap-list">
      <div class="cap">
        <div class="cap-h">Default opener</div>
        <p class="cap-p">Set Writ as the app for <code>.md</code>, <code>.log</code>, <code>.toml</code> and other text.</p>
      </div>
      <div class="cap">
        <div class="cap-h">Watched inbox</div>
        <p class="cap-p">New files in a folder list in the sidebar and open as they arrive.</p>
      </div>
      <div class="cap">
        <div class="cap-h">Copy as Prompt</div>
        <p class="cap-p">Grab a whole buffer to paste into a model.</p>
      </div>
      <div class="cap">
        <div class="cap-h">Fill <code>{'{{placeholders}}'}</code></div>
        <p class="cap-p">Prompt variables fill inline before you copy.</p>
      </div>
    </div>
  </div>
</Section>

<!-- THEMES -->
<Section slug="themes" id="themes">
  <h2 class="sec-h2">Six themes to start.</h2>
  <div class="theme-grid">
    {presets.map((p) => (
      <div class="theme-card">
        <div class="theme-chip" style={`background:${p.surface.background}; color:${p.foreground.default}`}>
          <div class="tchip-line"><span style={`color:${p.syntax.keyword}`}>theme</span> = <span style={`color:${p.syntax.string}`}>"{p.polarity}"</span><span class="tchip-caret" style={`background:${p.accent.default}`}></span></div>
          <div class="tchip-line"><span style={`color:${p.syntax.function}`}>font</span> = <span style={`color:${p.syntax.number}`}>14</span> <span style={`color:${p.syntax.comment}`}># px</span></div>
        </div>
        <div class="tchip-name">{p.name}</div>
      </div>
    ))}
  </div>
  <p class="sec-note">Change any color, and rebind any shortcut.</p>
</Section>

<!-- DOWNLOAD -->
<Section slug="install" id="download" lead>
  <h2 class="sec-h2-lg">Always a keypress away.</h2>
  <p class="sec-p sec-p-lg">A global hotkey brings Writ up over whatever you're in. Free, open source, no account.</p>

  {published ? (
    <div class="plat-grid">
      <div class="plat-card featured" data-plat="mac">
        <div class="plat-top">
          <span class="plat-name">macOS</span>
          {notarized && <span class="plat-badge">notarized</span>}
        </div>
        <a class="plat-dl" href={release.platforms.mac.pkg}>Download .pkg</a>
        <a class="plat-alt" href={release.platforms.mac.dmg}>or .dmg</a>
        <span class="plat-note">Apple silicon & Intel</span>
      </div>
      <div class="plat-card" data-plat="win">
        <div class="plat-top"><span class="plat-name">Windows</span></div>
        <a class="plat-dl" href={release.platforms.win.msi}>Download .msi</a>
        <span class="plat-note">x64</span>
      </div>
      <div class="plat-card" data-plat="linux">
        <div class="plat-top"><span class="plat-name">Linux</span></div>
        <a class="plat-dl" href={release.platforms.linux.appImage}>Download .AppImage</a>
        <a class="plat-alt" href={release.platforms.linux.deb}>or .deb</a>
      </div>
    </div>
  ) : (
    <div class="plat-grid">
      <div class="plat-card featured" data-plat="mac" aria-disabled="true">
        <div class="plat-top"><span class="plat-name">macOS</span></div>
        <span class="plat-note">Apple silicon & Intel</span>
      </div>
      <div class="plat-card" data-plat="win" aria-disabled="true">
        <div class="plat-top"><span class="plat-name">Windows</span></div>
        <span class="plat-note">x64</span>
      </div>
      <div class="plat-card" data-plat="linux" aria-disabled="true">
        <div class="plat-top"><span class="plat-name">Linux</span></div>
        <span class="plat-note">AppImage & .deb</span>
      </div>
    </div>
  )}

  <div class="oneliners">
    {oneliners.map((o) => (
      <div class="ol-row">
        <span class="ol-os">{o.os}</span>
        <code class="ol-cmd">{o.cmd}</code>
        <button class="copybtn" type="button" data-copy={o.cmd} aria-label={`Copy the ${o.os} install command`}><span>Copy</span></button>
      </div>
    ))}
  </div>

  {published ? (
    <p class="dl-foot">
      v{release.version} · updates itself · <a href={sumsUrl} rel="noopener noreferrer" target="_blank">checksums</a> · <a href={releasesUrl} rel="noopener noreferrer" target="_blank">Releases on GitHub</a>
    </p>
  ) : (
    <p class="dl-foot">
      Direct downloads are on <a href={releasesUrl} rel="noopener noreferrer" target="_blank">GitHub Releases</a>.
    </p>
  )}
</Section>
