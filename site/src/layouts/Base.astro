---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Lightweight, always-ready text editor for developers. Global hotkey, autosave, full-text search.',
  ogImage = 'og-image.svg',
  noindex = false,
} = Astro.props;

const siteName = 'Writ';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(`${base}/${ogImage}`, Astro.site).toString();
const fullTitle =
  title === siteName ? `${siteName}, a scratchpad text editor for developers` : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('writ-theme');
          const themes = ['warm-light', 'cool-light', 'warm-dark', 'cool-dark'];
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const fallback = prefersDark ? 'warm-dark' : 'warm-light';
          const theme = stored && themes.indexOf(stored) !== -1 ? stored : fallback;
          document.documentElement.setAttribute('data-theme', theme);
          const meta = document.querySelector('meta[name="theme-color"]');
          const themeColors = {
            'warm-light': '#faf8f5',
            'cool-light': '#f1f5f9',
            'warm-dark': '#171310',
            'cool-dark': '#0f172a',
          };
          if (meta) meta.setAttribute('content', themeColors[theme]);
        } catch (err) {
          document.documentElement.setAttribute('data-theme', 'warm-light');
        }
      })();
    </script>

    <meta name="theme-color" content="#faf8f5" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl.toString()} />

    <link rel="icon" type="image/png" sizes="32x32" href={`${base}/brand/icon-32.png`} />
    <link rel="icon" type="image/png" sizes="128x128" href={`${base}/brand/icon-128.png`} />
    <link rel="icon" type="image/png" sizes="256x256" href={`${base}/brand/icon-256.png`} />
    <link rel="apple-touch-icon" sizes="256x256" href={`${base}/brand/icon-256.png`} />
    <link rel="manifest" href={`${base}/site.webmanifest`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://rsms.me/" crossorigin />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
