---
import '../styles/fonts.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  path?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Writ renders agent output offline: Markdown, HTML, Mermaid and KaTeX. Keeps every scratch searchable. Local only, no account, no telemetry.',
  path = '/',
  ogImage = '/brand/og-image.svg',
} = Astro.props;

const SITE_URL = 'https://ibrahemid.github.io';
const BASE = '/writ';
const canonical = SITE_URL + BASE + (path === '/' ? '/' : path);
const ogImageAbsolute = SITE_URL + BASE + ogImage;
---
<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="preload" as="font" type="font/woff2" crossorigin href={`${import.meta.env.BASE_URL}fonts/bricolage-grotesque-latin-opsz.woff2`} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={`${import.meta.env.BASE_URL}fonts/inter-latin-variable.woff2`} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={`${import.meta.env.BASE_URL}fonts/jetbrains-mono-latin-400.woff2`} />

    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}brand/icon-32.png`} />
    <link rel="icon" type="image/png" sizes="128x128" href={`${import.meta.env.BASE_URL}brand/icon-128.png`} />
    <link rel="apple-touch-icon" sizes="256x256" href={`${import.meta.env.BASE_URL}brand/icon-256.png`} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('writ:theme');
          var theme = stored === 'dark' || stored === 'light' ? stored : 'light';
          document.documentElement.setAttribute('data-theme', theme);
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
