---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  path?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Writ — a scratchpad always one keypress away. Local only. Open source.',
  path = '/',
  ogImage = '/writ/brand/og-image.svg',
} = Astro.props;

const SITE_URL = 'https://ibrahemid.github.io/writ';
const canonical = SITE_URL + (path === '/' ? '/' : path);
---
<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" sizes="32x32" href="/writ/brand/icon-32.png" />
    <link rel="icon" type="image/png" sizes="128x128" href="/writ/brand/icon-128.png" />
    <link rel="apple-touch-icon" sizes="256x256" href="/writ/brand/icon-256.png" />

    <link
      rel="preload"
      href="/writ/fonts/JetBrainsMono[wght].woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/writ/fonts/Newsreader-Italic[opsz,wght].woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={SITE_URL + ogImage.replace('/writ', '')} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={SITE_URL + ogImage.replace('/writ', '')} />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('writ:theme');
          var theme = stored === 'dark' || stored === 'light' ? stored : 'light';
          document.documentElement.setAttribute('data-theme', theme);
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
