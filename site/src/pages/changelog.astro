---
import Base from '../layouts/Base.astro';

const releases = [
  {
    version: '0.1.0',
    date: '2026-04-29',
    label: 'first public preview',
    notes: [
      { kind: 'added', text: 'global hotkey: Cmd+Shift+Space (macOS), Ctrl+Shift+Space (Linux/Windows).' },
      { kind: 'added', text: 'browser-style tabs across buffers with persistent session state.' },
      { kind: 'added', text: 'autosave on every keystroke; buffers persist across restarts.' },
      { kind: 'added', text: 'full-text search across all buffers, backed by SQLite FTS5.' },
      { kind: 'added', text: 'command palette (Cmd+K) for new tab, switch tab, rename, export, toggle theme.' },
      { kind: 'added', text: 'CodeMirror 6 editor with syntax highlighting for .rs, .ts, .py, .md.' },
      { kind: 'added', text: 'macOS .dmg, Windows .msi, Linux .deb / .rpm / AppImage.' },
    ],
  },
  {
    version: '0.0.3',
    date: '2026-04-12',
    label: 'internal beta',
    notes: [
      { kind: 'changed', text: 'rewrote tab persistence on top of SQLite WAL.' },
      { kind: 'fixed',   text: 'autosave race when the OS suspends mid-write.' },
      { kind: 'fixed',   text: 'palette returned stale tab list after rapid create/close.' },
    ],
  },
  {
    version: '0.0.2',
    date: '2026-03-30',
    label: 'private alpha',
    notes: [
      { kind: 'added', text: 'first pass at the dark terminal-night theme.' },
      { kind: 'added', text: 'tray icon and global hotkey on Windows.' },
    ],
  },
  {
    version: '0.0.1',
    date: '2026-03-14',
    label: 'first build that opens',
    notes: [
      { kind: 'added', text: 'tauri shell, single-window editor, save-to-disk on quit.' },
    ],
  },
];

const kindColor: Record<string, string> = {
  added: 'var(--accent)',
  changed: 'var(--syntax-keyword)',
  fixed: 'var(--success)',
  removed: 'var(--destructive)',
};
---
<Base
  title="Writ — Changelog"
  description="Every release of Writ. What was added, changed, and fixed."
  path="/changelog/"
>
  <section class="cl">
    <div class="container container-narrow cl-inner">
      <header class="cl-head">
        <span class="eyebrow">/* changelog */</span>
        <h1>What changed.</h1>
        <p class="cl-sub">
          Rendered from <a href="https://github.com/ibrahemid/writ/blob/main/CHANGELOG.md" rel="noopener" target="_blank">CHANGELOG.md</a>.
          Newest first.
        </p>
      </header>

      {releases.map((r) => (
        <article class="rel" id={`v${r.version}`}>
          <hr class="rule" />
          <header class="rel-head">
            <h2>v{r.version}</h2>
            <span class="rel-date">{r.date}</span>
            <span class="rel-label">{r.label}</span>
          </header>
          <ul class="rel-notes">
            {r.notes.map((n) => (
              <li>
                <span class="rel-kind" style={{ color: kindColor[n.kind] || 'var(--muted-foreground)' }}>{n.kind}</span>
                <span class="rel-text">{n.text}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <style>
    .cl { padding: var(--space-12) 0 var(--space-16); }
    .cl-inner { display: flex; flex-direction: column; gap: var(--space-10); }
    .cl-head { display: flex; flex-direction: column; gap: var(--space-3); }
    .cl-head h1 {
      margin: 0;
      font-size: var(--text-3xl);
      letter-spacing: -0.025em;
    }
    .cl-sub { color: var(--muted-foreground); margin: 0; }

    .rel { display: flex; flex-direction: column; gap: var(--space-4); padding-top: var(--space-6); }
    .rel-head {
      display: flex;
      align-items: baseline;
      gap: var(--space-4);
      flex-wrap: wrap;
    }
    .rel-head h2 {
      margin: 0;
      font-family: var(--font-mono-display);
      font-size: var(--text-xl);
      color: var(--accent);
      letter-spacing: -0.015em;
    }
    .rel-date {
      font-family: var(--font-mono-display);
      font-size: var(--text-sm);
      color: var(--muted-foreground);
      font-feature-settings: 'tnum';
    }
    .rel-label {
      font-family: var(--font-mono-display);
      font-size: var(--text-xs);
      color: var(--ink-faint);
      text-transform: uppercase;
      letter-spacing: var(--tracking-caps);
    }
    .rel-notes { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-2); }
    .rel-notes li {
      display: grid;
      grid-template-columns: 84px 1fr;
      gap: var(--space-3);
      align-items: baseline;
      padding: var(--space-2) 0;
    }
    .rel-kind {
      font-family: var(--font-mono-display);
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: var(--tracking-caps);
      font-weight: 600;
    }
    .rel-text {
      font-family: var(--font-mono-display);
      font-size: var(--text-sm);
      color: var(--foreground);
      line-height: 1.6;
    }

    @media (max-width: 640px) {
      .rel-notes li { grid-template-columns: 64px 1fr; }
    }
  </style>
</Base>
