---
import Site from "../layouts/Site.astro";
import release from "../data/release.json";

const isPublished = release.published === true && release.publishedAt !== '';
const releaseDate = isPublished ? release.publishedAt : 'unreleased';

const notes = [
  { kind: 'added', text: 'global hotkey brings the window up over anything: Cmd+Shift+Space on macOS, Ctrl+Shift+Space on Linux and Windows.' },
  { kind: 'added', text: 'tabs across buffers, with reopen-closed recovery from history.' },
  { kind: 'added', text: 'autosave on every keystroke, no manual save; buffers persist across restarts.' },
  { kind: 'added', text: 'full-text search across every buffer, backed by SQLite FTS5.' },
  { kind: 'added', text: 'command palette on double-tap Shift.' },
  { kind: 'added', text: 'CodeMirror 6 editor with language detection by extension and file content.' },
  { kind: 'added', text: 'TOML configuration with hot reload.' },
  { kind: 'added', text: 'builds for macOS, Windows, and Linux: .dmg, .msi, .deb, and AppImage.' },
];

const kindColor: Record<string, string> = {
  added:   'var(--accent)',
  changed: 'var(--warn)',
  fixed:   'var(--success)',
  removed: 'var(--err)',
};
---
<Site
  title="Writ — Changelog"
  description="What ships in each release of Writ."
  path="/changelog/"
>
  <section class="cl">
    <div class="cl-wrap">
      <header class="cl-head">
        <h1>Changelog</h1>
        <p class="cl-sub">Newest first.</p>
      </header>

      <article class="rel" id={`v${release.version}`}>
        <hr class="rel-rule" />
        <header class="rel-head">
          <h2>v{release.version}</h2>
          <span class="rel-date">{releaseDate}</span>
          <span class="rel-label">first release</span>
        </header>
        <ul class="rel-notes">
          {notes.map((n) => (
            <li>
              <span class="rel-kind" style={{ color: kindColor[n.kind] || 'var(--muted)' }}>{n.kind}</span>
              <span class="rel-text">{n.text}</span>
            </li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  <style>
    .cl { padding: 6rem 0 8rem; }
    .cl-wrap { width: min(720px, 100% - 48px); margin: 0 auto; display: flex; flex-direction: column; gap: 3rem; }
    .cl-head { display: flex; flex-direction: column; gap: 0.5rem; }
    .cl-head h1 {
      font-family: var(--font-display);
      font-size: clamp(28px, 4vw, 46px);
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--foreground);
      margin: 0;
    }
    .cl-sub { color: var(--muted); margin: 0; font-family: var(--font-mono); font-size: 13px; }

    .rel { display: flex; flex-direction: column; gap: 1rem; }
    .rel-rule { border: none; border-top: 1px solid var(--line); margin: 0; }
    .rel-head {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      flex-wrap: wrap;
      padding-top: 1.25rem;
    }
    .rel-head h2 {
      margin: 0;
      font-family: var(--font-mono);
      font-size: 1.1rem;
      color: var(--accent);
      letter-spacing: -0.01em;
    }
    .rel-date {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
    }
    .rel-label {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--subtle);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .rel-notes { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem; }
    .rel-notes li {
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 0.75rem;
      align-items: baseline;
      padding: 0.35rem 0;
    }
    .rel-kind {
      font-family: var(--font-mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 600;
    }
    .rel-text {
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
    }

    @media (max-width: 640px) {
      .rel-notes li { grid-template-columns: 56px 1fr; }
    }
  </style>
</Site>
