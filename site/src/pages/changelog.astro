---
import Site from "../layouts/Site.astro";
import release from "../data/release.json";

const isPublished = release.published === true && release.publishedAt !== '';
const releaseDate = isPublished ? release.publishedAt : 'unreleased';

const notes = [
  { kind: 'added', text: 'split-pane live preview renders Markdown, HTML, Mermaid diagrams, and KaTeX math from bundled offline runtimes, with source and preview scroll in sync and find inside the preview.' },
  { kind: 'added', text: 'global hotkey brings the window up over anything: Cmd+Shift+Space on macOS, Ctrl+Shift+Space on Linux and Windows.' },
  { kind: 'added', text: 'tabbed CodeMirror 6 editor with language detection by extension and file content, live Markdown typography, and reopen-closed recovery.' },
  { kind: 'added', text: 'find and replace overlay with a live match count.' },
  { kind: 'added', text: 'full-text search across every buffer, with a results panel showing snippets and line numbers, backed by SQLite FTS5.' },
  { kind: 'added', text: 'command palette on double-tap Shift.' },
  { kind: 'added', text: 'settings window on Cmd+, with searchable settings and configurable shortcuts.' },
  { kind: 'added', text: 'editor and preview font zoom.' },
  { kind: 'added', text: 'status bar with language, encoding, and cursor position.' },
  { kind: 'added', text: 'prompt fill modal with placeholder variables, a live token estimate, and copy as prompt.' },
  { kind: 'added', text: 'text transforms: tidy whitespace, plus composable passes for trailing spaces, final newline, and punctuation spacing.' },
  { kind: 'added', text: 'local spell check: wavy underlines on likely misspellings, with fix all, a preview list, and per-word ignore from the status bar. Off by default; code, URLs, and links stay unflagged.' },
  { kind: 'added', text: 'rewrite a selection to proofread, rephrase, or polish it with a local model by default, or a hosted provider with your own key held in the OS keychain. Off until you turn it on, and text is sent only when you run a rewrite.' },
  { kind: 'added', text: 'open a folder as a workspace with a sidebar file tree; a watched folder lists new files and opens them as they arrive.' },
  { kind: 'added', text: 'writ command-line tool for opening files from the terminal; set Writ as the default app on macOS for Markdown, plain text, config, and source files.' },
  { kind: 'added', text: 'app-wide light and dark themes, autosave with crash recovery, and self-update with signed manifests.' },
  { kind: 'added', text: 'builds for macOS, Windows, and Linux: .dmg, .msi, .deb, and AppImage.' },
];

const kindColor: Record<string, string> = {
  added:   'var(--accent)',
  changed: 'var(--warn)',
  fixed:   'var(--success)',
  removed: 'var(--err)',
};
---
<Site
  title="Writ — Changelog"
  description="What ships in each release of Writ."
  path="/changelog/"
>
  <section class="cl">
    <div class="cl-wrap">
      <header class="cl-head">
        <h1>Changelog</h1>
        <p class="cl-sub">Newest first.</p>
      </header>

      <article class="rel" id={`v${release.version}`}>
        <hr class="rel-rule" />
        <header class="rel-head">
          <h2>v{release.version}</h2>
          <span class="rel-date">{releaseDate}</span>
          <span class="rel-label">first release</span>
        </header>
        <ul class="rel-notes">
          {notes.map((n) => (
            <li>
              <span class="rel-kind" style={{ color: kindColor[n.kind] || 'var(--muted)' }}>{n.kind}</span>
              <span class="rel-text">{n.text}</span>
            </li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  <style>
    .cl { padding: 6rem 0 8rem; }
    .cl-wrap { width: min(720px, 100% - 48px); margin: 0 auto; display: flex; flex-direction: column; gap: 3rem; }
    .cl-head { display: flex; flex-direction: column; gap: 0.5rem; }
    .cl-head h1 {
      font-family: var(--font-display);
      font-size: clamp(28px, 4vw, 46px);
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--foreground);
      margin: 0;
    }
    .cl-sub { color: var(--muted); margin: 0; font-family: var(--font-mono); font-size: 13px; }

    .rel { display: flex; flex-direction: column; gap: 1rem; }
    .rel-rule { border: none; border-top: 1px solid var(--line); margin: 0; }
    .rel-head {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      flex-wrap: wrap;
      padding-top: 1.25rem;
    }
    .rel-head h2 {
      margin: 0;
      font-family: var(--font-mono);
      font-size: 1.1rem;
      color: var(--accent);
      letter-spacing: -0.01em;
    }
    .rel-date {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
    }
    .rel-label {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--subtle);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .rel-notes { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem; }
    .rel-notes li {
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 0.75rem;
      align-items: baseline;
      padding: 0.35rem 0;
    }
    .rel-kind {
      font-family: var(--font-mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 600;
    }
    .rel-text {
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
    }

    @media (max-width: 640px) {
      .rel-notes li { grid-template-columns: 56px 1fr; }
    }
  </style>
</Site>
