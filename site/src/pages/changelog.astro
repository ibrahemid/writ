---
import Base from '../layouts/Base.astro';

const releases = [
  {
    version: '0.1.0',
    date: '2026-04-29',
    label: 'first public preview',
    notes: [
      { kind: 'added', text: 'global hotkey: Cmd+Shift+Space (macOS), Ctrl+Shift+Space (Linux/Windows).' },
      { kind: 'added', text: 'browser-style tabs across buffers with persistent session state.' },
      { kind: 'added', text: 'autosave on every keystroke; buffers persist across restarts.' },
      { kind: 'added', text: 'full-text search across all buffers, backed by SQLite FTS5.' },
      { kind: 'added', text: 'command palette (tap Shift twice) for new tab, switch tab, rename, toggle theme, open settings.' },
      { kind: 'added', text: 'CodeMirror 6 editor with syntax highlighting for .rs, .ts, .py, .md.' },
      { kind: 'added', text: 'macOS .dmg, Windows .msi, Linux .deb / AppImage.' },
    ],
  },
  {
    version: '0.0.3',
    date: '2026-04-12',
    label: 'pre-release',
    notes: [
      { kind: 'changed', text: 'rewrote tab persistence on top of SQLite WAL.' },
      { kind: 'fixed',   text: 'autosave race when the OS suspends mid-write.' },
      { kind: 'fixed',   text: 'palette returned stale tab list after rapid create/close.' },
    ],
  },
  {
    version: '0.0.2',
    date: '2026-03-30',
    label: 'pre-release',
    notes: [
      { kind: 'added', text: 'first pass at the dark terminal-night theme.' },
      { kind: 'added', text: 'tray icon and global hotkey on Windows.' },
    ],
  },
  {
    version: '0.0.1',
    date: '2026-03-14',
    label: 'first build',
    notes: [
      { kind: 'added', text: 'tauri shell, single-window editor, save-to-disk on quit.' },
    ],
  },
];

const kindColor: Record<string, string> = {
  added:   'var(--accent)',
  changed: 'var(--warn)',
  fixed:   'var(--ok)',
  removed: 'var(--err)',
};
---
<Base
  title="Writ — Changelog"
  description="Every release of Writ. What was added, changed, and fixed."
  path="/changelog/"
>
  <section class="cl">
    <div class="cl-wrap">
      <header class="cl-head">
        <h1>Changelog</h1>
        <p class="cl-sub">Newest first.</p>
      </header>

      {releases.map((r) => (
        <article class="rel" id={`v${r.version}`}>
          <hr class="rel-rule" />
          <header class="rel-head">
            <h2>v{r.version}</h2>
            <span class="rel-date">{r.date}</span>
            <span class="rel-label">{r.label}</span>
          </header>
          <ul class="rel-notes">
            {r.notes.map((n) => (
              <li>
                <span class="rel-kind" style={{ color: kindColor[n.kind] || 'var(--muted)' }}>{n.kind}</span>
                <span class="rel-text">{n.text}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <style>
    .cl { padding: 6rem 0 8rem; }
    .cl-wrap { width: min(720px, 100% - 48px); margin: 0 auto; display: flex; flex-direction: column; gap: 3rem; }
    .cl-head { display: flex; flex-direction: column; gap: 0.5rem; }
    .cl-head h1 {
      font-family: var(--disp);
      font-size: clamp(28px, 4vw, 46px);
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--ink);
      margin: 0;
    }
    .cl-sub { color: var(--muted); margin: 0; font-family: var(--mono); font-size: 13px; }

    .rel { display: flex; flex-direction: column; gap: 1rem; }
    .rel-rule { border: none; border-top: 1px solid var(--line); margin: 0; }
    .rel-head {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      flex-wrap: wrap;
      padding-top: 1.25rem;
    }
    .rel-head h2 {
      margin: 0;
      font-family: var(--mono);
      font-size: 1.1rem;
      color: var(--accent);
      letter-spacing: -0.01em;
    }
    .rel-date {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
    }
    .rel-label {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--subtle);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .rel-notes { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem; }
    .rel-notes li {
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 0.75rem;
      align-items: baseline;
      padding: 0.35rem 0;
    }
    .rel-kind {
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 600;
    }
    .rel-text {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
    }

    @media (max-width: 640px) {
      .rel-notes li { grid-template-columns: 56px 1fr; }
    }
  </style>
</Base>
