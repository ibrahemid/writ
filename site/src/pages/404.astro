---
import Base from '../layouts/Base.astro';
---
<Base
  title="404 — this page wasn't autosaved"
  description="The page you asked for does not exist."
  path="/404/"
>
  <section class="nf">
    <div class="container nf-inner">
      <div class="nf-frame" role="img" aria-label="A simulated Writ buffer titled 404.md">
        <div class="nf-chrome">
          <div class="nf-traffic" aria-hidden="true">
            <span style="background: var(--traffic-close)"></span>
            <span style="background: var(--traffic-min)"></span>
            <span style="background: var(--traffic-max)"></span>
          </div>
          <div class="nf-tabs" aria-hidden="true">
            <span class="nf-tab is-active">404.md</span>
          </div>
          <div class="nf-keys" aria-hidden="true">
            <kbd>⌘</kbd><kbd>⇧</kbd><kbd>Space</kbd>
          </div>
        </div>

        <pre class="nf-pre">
          <code>{`# 404

> this page wasn't autosaved.

the URL you followed doesn't match any buffer Writ knows about.
nothing was lost — there was nothing here to begin with.

try one of:
  - /        ←  home
  - /download  ←  binaries & one-liners
  - /changelog ←  what shipped
`}</code>
        </pre>

        <div class="nf-status">
          <span class="nf-dot" aria-hidden="true"></span>
          <span>not found · 404</span>
          <span class="nf-status-right">
            <a href="/writ/" class="bracket-link">go home</a>
          </span>
        </div>
      </div>
    </div>
  </section>

  <style>
    .nf { padding: var(--space-16) 0; }
    .nf-inner { max-width: 720px; margin: 0 auto; }
    .nf-frame {
      border-radius: var(--radius-lg);
      overflow: hidden;
      background: var(--syntax-bg);
      border: 1px solid var(--border-strong);
      box-shadow: var(--card-shadow-hover);
      font-family: var(--font-mono-display);
    }
    .nf-chrome {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      background: color-mix(in oklab, var(--syntax-bg) 70%, var(--background));
      border-bottom: 1px solid var(--border);
    }
    .nf-traffic { display: flex; gap: 6px; }
    .nf-traffic span { width: 11px; height: 11px; border-radius: 999px; display: block; }
    .nf-tabs { display: flex; gap: 6px; flex: 1; }
    .nf-tab {
      font-size: 12px;
      padding: 4px 10px;
      border-radius: 6px;
      color: var(--syntax-fg);
      background: var(--background);
      border: 1px solid var(--border);
    }
    .nf-keys { margin-left: auto; display: inline-flex; gap: 4px; }
    .nf-keys kbd { font-size: 11px; }

    .nf-pre {
      margin: 0;
      padding: var(--space-6);
      font-family: var(--font-mono-display);
      font-size: var(--text-sm);
      line-height: 1.75;
      color: var(--syntax-fg);
      white-space: pre;
      overflow-x: auto;
    }

    .nf-status {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 14px;
      font-size: 12px;
      color: var(--muted-foreground);
      border-top: 1px solid var(--border);
      background: color-mix(in oklab, var(--syntax-bg) 70%, var(--background));
    }
    .nf-dot {
      width: 7px; height: 7px; border-radius: 999px;
      background: var(--destructive);
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--destructive) 22%, transparent);
    }
    .nf-status-right { margin-left: auto; }
  </style>
</Base>
