---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Page not found" description="The page you were looking for does not exist." noindex>
  <section class="section">
    <div class="container not-found">
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p class="muted">
        We could not find the page you were looking for. It might have moved, or the link might be broken.
      </p>
      <div class="actions">
        <a class="btn btn-primary btn-lg" href={`${base}/`}>Back to home</a>
        <a class="btn btn-lg" href={`${base}/download`}>Go to download</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .not-found {
    max-width: 600px;
    margin: 4rem auto;
    text-align: center;
  }
  .eyebrow {
    display: inline-block;
    margin: 0 0 0.5rem;
    padding: 0.2rem 0.6rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 15%, transparent);
    border: 1px solid color-mix(in oklab, var(--accent) 30%, transparent);
    border-radius: 999px;
  }
  .actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }
</style>
