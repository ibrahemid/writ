---
import Site from '../layouts/Site.astro';
import Hero from '../components/site/Hero.astro';
import WindowRow from '../components/site/WindowRow.astro';
import Sections from '../components/site/Sections.astro';
---
<Site title="Writ — a fast scratchpad for everything you open" path="/">
  <main id="top" class="v2-grid">
    <Hero />
    <WindowRow />
    <Sections />
  </main>
</Site>

<script>
  (function () {
    document.querySelectorAll('[data-cmd]').forEach((el) => {
      el.addEventListener('click', () => {
        const action = el.getAttribute('data-cmd');
        const arg = el.getAttribute('data-arg') || undefined;
        if (!action) return;
        document.dispatchEvent(new CustomEvent('writ:cmd', { detail: { action, arg } }));
      });
    });
  })();
</script>
