---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import Proof from '../components/Proof.astro';
import Comparison from '../components/Comparison.astro';
import Shortcuts from '../components/Shortcuts.astro';
import Faq from '../components/Faq.astro';
import release from '../data/release.json';

const siteUrl = new URL(Astro.url.pathname, Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Writ',
  description:
    'Lightweight, always-ready text editor for developers. Global hotkey, autosave, full-text search.',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Windows, Linux',
  url: siteUrl,
  softwareVersion: release.version,
  downloadUrl: 'https://github.com/ibrahemid/writ/releases/latest',
  license: 'https://opensource.org/licenses/MIT',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Person',
    name: 'ibrahemid',
    url: 'https://github.com/ibrahemid',
  },
};
---

<Base
  title="Writ"
  description="Lightweight, always-ready text editor for developers. Global hotkey, autosave, full-text search."
>
  <script
    slot="head"
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />
  <Hero />
  <FeatureGrid />
  <Proof />
  <Comparison />
  <Shortcuts />
  <Faq />
</Base>
