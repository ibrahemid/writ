---
import Site from '../layouts/Site.astro';
import Hero from '../components/site/Hero.astro';
import WindowRow from '../components/site/WindowRow.astro';
import Sections from '../components/site/Sections.astro';
import { EDITOR_COMMAND_KEYS } from '../../../src/editor/editor-command-keys';
import { keybindingSegments } from '../../../src/lib/keybinding-format';
import warpLight from '../../../src/styles/themes/warp-light.json';
import warpDark from '../../../src/styles/themes/warp-dark.json';
import tokyoNight from '../../../src/styles/themes/tokyo-night.json';
import dracula from '../../../src/styles/themes/dracula.json';
import solarizedDark from '../../../src/styles/themes/solarized-dark.json';
import catppuccinMocha from '../../../src/styles/themes/catppuccin-mocha.json';

const presets = [warpLight, warpDark, tokyoNight, dracula, solarizedDark, catppuccinMocha];

// Keycaps use the app's own segmenter so the sheet matches the window exactly.
// isMac is forced: navigator is undefined at build time and would default to non-mac.
const seg = (binding: string) => keybindingSegments(binding, { isMac: true });
const appShortcuts = [
  { label: 'Toggle window', bindings: ['CmdOrCtrl+Shift+Space'] },
  { label: 'Command palette', bindings: ['Shift+Shift'] },
  { label: 'New tab', bindings: ['CmdOrCtrl+T'] },
  { label: 'Close tab', bindings: ['CmdOrCtrl+W'] },
  { label: 'Switch tabs', bindings: ['CmdOrCtrl+[', 'CmdOrCtrl+]'] },
  { label: 'Toggle sidebar', bindings: ['CmdOrCtrl+S'] },
  { label: 'Find in document', bindings: ['CmdOrCtrl+F'] },
  { label: 'Bold / italic / link', bindings: ['CmdOrCtrl+B', 'CmdOrCtrl+I', 'CmdOrCtrl+K'] },
];
const kcCols = [
  { h: 'window & tabs', rows: appShortcuts.map((r) => ({ label: r.label, groups: r.bindings.map(seg) })) },
  { h: 'editing', rows: EDITOR_COMMAND_KEYS.map((c) => ({ label: c.label, groups: [seg(c.keybinding)] })) },
];
---
<Site title="Writ — a fast scratchpad for everything you open" path="/">
  <main id="top" class="v2-grid">
    <div class="spine" aria-hidden="true"></div>
    <Hero />
    <WindowRow />
    <Sections kcCols={kcCols} presets={presets} />
  </main>
</Site>

<script>
  (function () {
    document.querySelectorAll('[data-cmd]').forEach((el) => {
      el.addEventListener('click', () => {
        const action = el.getAttribute('data-cmd');
        const arg = el.getAttribute('data-arg') || undefined;
        if (!action) return;
        document.dispatchEvent(new CustomEvent('writ:cmd', { detail: { action, arg } }));
      });
    });

    const root = document.documentElement;
    const sections = Array.from(document.querySelectorAll<HTMLElement>('.rv'));
    const winGut = document.querySelector<HTMLElement>('[data-rv-win]');
    const revealSection = (el: HTMLElement) => {
      el.classList.add('in');
      const gut = el.previousElementSibling;
      if (gut && gut.classList.contains('rv-g')) gut.classList.add('in');
    };
    const revealAll = () => {
      sections.forEach(revealSection);
      if (winGut) winGut.classList.add('in');
    };
    if (root.getAttribute('data-writ-intro') !== 'play') {
      revealAll();
      return;
    }

    const mobile = window.matchMedia('(max-width: 880px)').matches;
    const winAt = mobile ? 0.8 : 2.05;
    // Section timings derive from document order so the cascade scales to any
    // number of sections instead of collapsing onto a fixed final slot.
    const firstAt = mobile ? 2.0 : 3.3;
    const step = mobile ? 0.2 : 0.32;
    const atOf = (i: number) => firstAt + i * step;
    const timers: number[] = [];

    const spine = document.querySelector<HTMLElement>('.spine');
    const main = document.getElementById('top');
    let currentAnim: Animation | null = null;
    let currentScale = 0;
    const fractionOf = (el: HTMLElement | null): number => {
      if (!main) return 1;
      const height = main.scrollHeight;
      if (!el) return 1;
      const mainTop = main.getBoundingClientRect().top;
      return Math.min(Math.max((el.getBoundingClientRect().top - mainTop) / height, 0), 1);
    };
    const growTo = (fraction: number, seconds: number) => {
      if (!spine || mobile) return;
      try {
        if (currentAnim) currentAnim.commitStyles();
      } catch (_) {}
      if (currentAnim) currentAnim.cancel();
      currentAnim = spine.animate(
        [{ transform: `scaleY(${currentScale})` }, { transform: `scaleY(${fraction})` }],
        { duration: Math.max(seconds, 0.01) * 1000, easing: 'linear', fill: 'forwards' },
      );
      currentScale = fraction;
    };

    interface Step {
      at: number;
      run: () => void;
    }
    const steps: Step[] = [];
    const win = document.querySelector<HTMLElement>('.win-rise');
    steps.push({
      at: 0.15,
      run: () => growTo(fractionOf(win), winAt - 0.15),
    });
    steps.push({
      at: winAt,
      run: () => {
        if (winGut) winGut.classList.add('in');
        const next = sections[0] ?? null;
        growTo(fractionOf(next), atOf(0) - winAt);
      },
    });
    sections.forEach((el, i) => {
      const at = atOf(i);
      const nextAt = atOf(i + 1);
      steps.push({
        at,
        run: () => {
          revealSection(el);
          const next = sections[i + 1] ?? null;
          growTo(fractionOf(next), nextAt - at);
        },
      });
    });
    steps.forEach((step) => timers.push(window.setTimeout(step.run, step.at * 1000)));

    const observer = new MutationObserver(() => {
      if (root.getAttribute('data-writ-intro') !== 'done') return;
      timers.forEach((t) => clearTimeout(t));
      revealAll();
      if (currentAnim) currentAnim.cancel();
      if (spine) spine.style.transform = 'none';
      observer.disconnect();
    });
    observer.observe(root, { attributes: true, attributeFilter: ['data-writ-intro'] });
  })();
</script>

<script>
  (function () {
    interface NavUAD {
      userAgentData?: { platform?: string };
    }
    const detectPlatform = (): 'mac' | 'win' | 'linux' => {
      const uad = (navigator as unknown as NavUAD).userAgentData;
      const p = (uad?.platform || navigator.userAgent || '').toLowerCase();
      if (p.includes('win')) return 'win';
      if (p.includes('linux') && !p.includes('android')) return 'linux';
      return 'mac';
    };
    const plat = detectPlatform();

    // The hero CTA label is owned by Hero.astro (it drives the source line too);
    // here we only feature the visitor's download card.
    document.querySelectorAll<HTMLElement>('.plat-card').forEach((card) => {
      card.classList.toggle('featured', card.dataset.plat === plat);
    });

    const oneliners = document.querySelector<HTMLElement>('.oneliners');
    oneliners?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement | null)?.closest<HTMLElement>('.copybtn');
      if (!btn) return;
      const text = btn.dataset.copy;
      const labelEl = btn.querySelector('span');
      if (!text || !labelEl) return;
      navigator.clipboard?.writeText(text).then(() => {
        const prev = labelEl.textContent;
        labelEl.textContent = 'copied';
        btn.classList.add('copied');
        window.setTimeout(() => {
          labelEl.textContent = prev;
          btn.classList.remove('copied');
        }, 1400);
      }).catch(() => {});
    });
  })();
</script>
