---
import Base from '../layouts/Base.astro';
import release from '../data/release.json';

const repoReleases = 'https://github.com/ibrahemid/writ/releases';

const sections = [
  {
    os: 'mac',
    title: 'macOS',
    badge: 'Universal · Apple Silicon + Intel',
    commands: [
      { label: 'Homebrew', cmd: 'brew install --cask writ' },
    ],
    items: [
      {
        name: 'Apple Silicon (.dmg)',
        sub: 'M1, M2, M3, M4',
        href: release.assets['mac-arm64'],
        primary: true,
      },
      {
        name: 'Intel (.dmg)',
        sub: 'x86_64',
        href: release.assets['mac-x64'],
      },
    ],
    notes:
      'Not yet notarized. On first launch, right-click the app and choose Open. Code signing is planned for v0.2.',
  },
  {
    os: 'win',
    title: 'Windows',
    badge: 'Windows 10 · Windows 11',
    commands: [
      { label: 'winget', cmd: 'winget install Writ.Writ' },
      { label: 'Scoop', cmd: 'scoop install writ' },
    ],
    items: [
      {
        name: 'x64 installer (.msi)',
        sub: 'Recommended',
        href: release.assets['win-x64'],
        primary: true,
      },
    ],
    notes:
      'Not yet code-signed. SmartScreen may prompt on first launch — click More info, then Run anyway.',
  },
  {
    os: 'linux',
    title: 'Linux',
    badge: 'x86_64',
    commands: [
      { label: 'Arch (AUR)', cmd: 'yay -S writ-bin' },
      { label: 'Debian / Ubuntu', cmd: 'sudo apt install ./writ.deb' },
    ],
    items: [
      {
        name: 'AppImage',
        sub: 'Portable, runs on most distros',
        href: release.assets['linux-appimage'],
        primary: true,
      },
      {
        name: 'Debian package (.deb)',
        sub: 'Ubuntu, Debian, Pop!_OS',
        href: release.assets['linux-deb'],
      },
    ],
    notes:
      'Flatpak and Snap packages are planned. AUR is community-maintained.',
  },
];
---

<Base
  title="Download"
  description="Install Writ on macOS, Windows, or Linux. Homebrew, winget, AUR one-liners plus direct installers."
  ogImage="og-download.svg"
>
  <section class="section">
    <div class="container">
      <header class="page-head">
        <p class="eyebrow">Download</p>
        <h1>Install Writ</h1>
        <p class="lede">
          Current stable: <strong>v{release.version}</strong>.
          <a href={repoReleases} rel="noopener noreferrer">Browse all releases.</a>
        </p>
        <p class="detection-note" data-detection hidden>
          Detected <strong data-detection-os>your system</strong>. Scrolled to the right section.
        </p>
      </header>

      <div class="os-grid">
        {sections.map((s) => (
          <section class={`os-card os-card--${s.os} reveal`} id={`os-${s.os}`} data-os-card={s.os}>
              <header class="os-head">
                <h2>{s.title}</h2>
                <span class="os-badge">{s.badge}</span>
              </header>

              {s.commands.length > 0 && (
                <div class="os-cmds">
                  {s.commands.map((c) => (
                    <div class="os-cmd">
                      <span class="os-cmd-label">{c.label}</span>
                      <code class="os-cmd-code" data-copy-source>{c.cmd}</code>
                      <button
                        type="button"
                        class="os-cmd-copy"
                        aria-label={`Copy ${c.label} install command`}
                        data-copy-btn
                      >
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                        </svg>
                        <span class="visually-hidden">Copy command</span>
                      </button>
                    </div>
                  ))}
                </div>
              )}

              <p class="os-direct-label">Or download directly</p>
              <ul class="os-items" role="list">
                {s.items.map((item) => (
                  <li>
                    <a
                      class={`btn os-item ${item.primary ? 'btn-primary' : ''}`}
                      href={item.href}
                      rel="noopener"
                    >
                      <span class="os-item-name">{item.name}</span>
                      <span class="os-item-sub">{item.sub}</span>
                    </a>
                  </li>
                ))}
              </ul>

            <p class="os-notes muted">{s.notes}</p>
          </section>
        ))}
      </div>

      <aside class="verify">
        <div class="verify-inner">
          <div class="verify-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6l-8-4Z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <div>
            <h3>Verify your download</h3>
            <p class="muted">
              Each release ships a <code>SHA256SUMS.txt</code> on the
              <a href={repoReleases} rel="noopener noreferrer"> releases page</a>.
              Compare it against the hash of your download before running.
            </p>
          </div>
        </div>
      </aside>

      <aside class="source">
        <h3>Prefer to build from source?</h3>
        <pre class="source-pre" aria-label="Build from source"><code>git clone https://github.com/ibrahemid/writ
cd writ
pnpm install
cargo tauri build</code></pre>
      </aside>
    </div>
  </section>
</Base>

<style>
  .page-head {
    max-width: 720px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }
  .lede strong {
    color: var(--foreground);
    font-weight: 500;
  }
  .detection-note {
    margin: 0.75rem auto 0;
    padding: 0.5rem 0.85rem;
    font-size: 0.85rem;
    color: var(--muted-foreground);
    background: var(--accent-soft);
    border: 1px solid color-mix(in oklab, var(--accent) 24%, transparent);
    border-radius: var(--radius-full);
    display: inline-block;
  }
  .detection-note strong {
    color: var(--accent);
    font-weight: 500;
  }
  .os-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    align-items: stretch;
  }
  .os-grid :global(> div) {
    display: flex;
  }
  .os-card {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.5rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--card-shadow);
    width: 100%;
    transition:
      transform var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out);
  }
  .os-card.is-matched {
    border-color: color-mix(in oklab, var(--accent) 40%, var(--border));
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }
  .os-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .os-head h2 {
    margin: 0;
    font-size: 1.25rem;
  }
  .os-badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted-foreground);
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    white-space: nowrap;
  }
  .os-cmds {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .os-cmd {
    display: grid;
    grid-template-columns: 84px 1fr auto;
    gap: 0.5rem;
    align-items: center;
    padding: 0.5rem 0.6rem 0.5rem 0.8rem;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .os-cmd-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--muted-foreground);
    font-weight: 500;
  }
  .os-cmd-code {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--foreground);
    background: transparent;
    border: 0;
    padding: 0;
    overflow-x: auto;
    white-space: nowrap;
  }
  .os-cmd-copy {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--muted-foreground);
    cursor: pointer;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }
  .os-cmd-copy:hover {
    background: var(--muted);
    color: var(--foreground);
  }
  .os-cmd-copy.is-copied {
    border-color: var(--success);
    color: var(--success);
  }
  .os-direct-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--muted-foreground);
    margin: 0.25rem 0 0.1rem;
    font-weight: 500;
  }
  .os-items {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .os-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
    padding: 0.8rem 1rem;
  }
  .os-item-name {
    font-weight: 500;
    font-size: 0.95rem;
  }
  .os-item-sub {
    font-size: 0.8rem;
    opacity: 0.85;
  }
  .os-notes {
    margin: auto 0 0;
    font-size: 0.84rem;
    line-height: 1.55;
  }
  .verify,
  .source {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--card-shadow);
  }
  .verify-inner {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .verify-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    color: var(--accent);
    background: var(--accent-soft);
    border: 1px solid color-mix(in oklab, var(--accent) 24%, transparent);
    flex: 0 0 auto;
  }
  .verify h3,
  .source h3 {
    margin: 0 0 0.4rem;
    font-size: 1rem;
  }
  .verify p,
  .source p {
    margin: 0;
    font-size: 0.92rem;
  }
  .verify code {
    padding: 0.1em 0.4em;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.85em;
  }
  .source-pre {
    margin: 0.5rem 0 0;
    padding: 1rem 1.25rem;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow-x: auto;
    font-size: 0.85rem;
    color: var(--foreground);
  }
</style>

<script>
  type OS = 'mac' | 'win' | 'linux';

  function detectOs(): OS | null {
    if (typeof navigator === 'undefined') return null;
    const nav = navigator as Navigator & { userAgentData?: { platform?: string } };
    const p = (nav.userAgentData?.platform || nav.platform || '').toLowerCase();
    const ua = (navigator.userAgent || '').toLowerCase();
    if (p.includes('mac') || ua.includes('mac os')) return 'mac';
    if (p.includes('win') || ua.includes('windows')) return 'win';
    if (p.includes('linux') || ua.includes('linux')) return 'linux';
    return null;
  }

  const os = detectOs();
  if (os) {
    const card = document.querySelector<HTMLElement>(`[data-os-card='${os}']`);
    if (card) {
      card.classList.add('is-matched');
      setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'center' }), 300);
    }
    const note = document.querySelector<HTMLElement>('[data-detection]');
    const osLabel = document.querySelector<HTMLElement>('[data-detection-os]');
    if (note && osLabel) {
      const label = os === 'mac' ? 'macOS' : os === 'win' ? 'Windows' : 'Linux';
      osLabel.textContent = label;
      note.hidden = false;
    }
  }

  document.querySelectorAll<HTMLButtonElement>('[data-copy-btn]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const cmd = btn.parentElement?.querySelector<HTMLElement>('[data-copy-source]');
      if (!cmd) return;
      try {
        await navigator.clipboard.writeText(cmd.textContent ?? '');
        btn.classList.add('is-copied');
        setTimeout(() => btn.classList.remove('is-copied'), 1200);
      } catch {
        /* ignore */
      }
    });
  });
</script>
