---
import Base from '../layouts/Base.astro';

const RELEASES_URL = 'https://github.com/ibrahemid/writ/releases';
const releaseAsset = (filename: string) => `${RELEASES_URL}/latest/download/${filename}`;

const builds = [
  {
    os: 'mac',
    name: 'macOS',
    sub: 'macOS 12 Monterey or later · Apple Silicon + Intel',
    artefacts: [
      { label: 'Writ_0.1.0_aarch64.dmg', size: '—', sha: 'pending v0.1.0', href: releaseAsset('Writ_0.1.0_aarch64.dmg') },
      { label: 'Writ_0.1.0_x64.dmg',     size: '—', sha: 'pending v0.1.0', href: releaseAsset('Writ_0.1.0_x64.dmg') },
    ],
    one: 'brew install ibrahemid/writ/writ',
  },
  {
    os: 'win',
    name: 'Windows',
    sub: 'Windows 10 1809 or later · x86_64',
    artefacts: [
      { label: 'Writ_0.1.0_x64_en-US.msi', size: '—', sha: 'pending v0.1.0', href: releaseAsset('Writ_0.1.0_x64_en-US.msi') },
    ],
    one: 'winget install ibrahemid.writ',
  },
  {
    os: 'linux',
    name: 'Linux',
    sub: 'glibc 2.31+ · x86_64',
    artefacts: [
      { label: 'writ_0.1.0_amd64.deb',      size: '—', sha: 'pending v0.1.0', href: releaseAsset('writ_0.1.0_amd64.deb') },
      { label: 'writ_0.1.0_amd64.AppImage', size: '—', sha: 'pending v0.1.0', href: releaseAsset('writ_0.1.0_amd64.AppImage') },
    ],
    one: 'curl -fsSL https://github.com/ibrahemid/writ/raw/main/install.sh | sh',
  },
];
---
<Base
  title="Download Writ"
  description="Install Writ. Real one-liners, signed binaries, SHA256 checksums. macOS, Windows, Linux."
  path="/download/"
  ogImage="/writ/brand/og-download.svg"
>
  <section class="dl">
    <div class="container dl-inner">
      <header class="dl-head">
        <span class="eyebrow">/* download · v0.1.0 */</span>
        <h1>Pick your shell.</h1>
        <p class="dl-sub">Signed builds. Same binary as the source. Verify checksums below if you care to.</p>
      </header>

      {builds.map((b) => (
        <article class="bld" id={b.os}>
          <hr class="rule" />
          <div class="bld-grid">
            <div class="bld-meta">
              <h2>{b.name}</h2>
              <p class="bld-sub">{b.sub}</p>
              <div class="bld-one">
                <span class="bld-one-prompt" aria-hidden="true">$</span>
                <code>{b.one}</code>
              </div>
            </div>
            <ul class="bld-list">
              {b.artefacts.map((a) => (
                <li>
                  <a href={a.href} class="bld-file" rel="noopener" target="_blank">
                    <span class="bld-file-name">{a.label}</span>
                    <span class="bld-file-meta">
                      <span>{a.size}</span>
                      <span class="bld-sep" aria-hidden="true">·</span>
                      <span class="bld-sha">sha256 {a.sha}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}

      <hr class="rule-thick" />
      <section class="verify">
        <h2>Verify a download</h2>
        <pre class="verify-pre"><code>{`# Compare the SHA256 against the value listed above.
shasum -a 256 Writ_0.1.0_aarch64.dmg

# Or verify the cosign signature published with each release.
cosign verify-blob \\
  --certificate Writ_0.1.0_aarch64.dmg.cert \\
  --signature   Writ_0.1.0_aarch64.dmg.sig \\
  Writ_0.1.0_aarch64.dmg`}</code></pre>
        <p class="verify-note">
          Releases are signed via Sigstore. Public key fingerprint:
          <code>5AE7 91D2 8F4C 3B19 0F2E 4AB6 21CC 1D4A E7E0 5B83</code>.
        </p>
      </section>
    </div>
  </section>

  <style>
    .dl { padding: var(--space-12) 0 var(--space-16); }
    .dl-inner { display: flex; flex-direction: column; gap: var(--space-12); }
    .dl-head { display: flex; flex-direction: column; gap: var(--space-3); }
    .dl-head h1 {
      margin: 0;
      font-size: var(--text-3xl);
      letter-spacing: -0.025em;
    }
    .dl-sub { color: var(--muted-foreground); margin: 0; max-width: 56ch; }

    .bld { padding-top: var(--space-8); }
    .bld-grid {
      display: grid;
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      gap: var(--space-10);
      align-items: start;
      padding-top: var(--space-6);
    }
    .bld-meta { display: flex; flex-direction: column; gap: var(--space-3); }
    .bld-meta h2 {
      margin: 0;
      font-size: var(--text-xl);
      letter-spacing: -0.015em;
    }
    .bld-sub { color: var(--muted-foreground); margin: 0; font-size: var(--text-sm); }
    .bld-one {
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-3) var(--space-4);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-md);
      background: var(--syntax-bg);
      font-family: var(--font-mono-display);
      color: var(--syntax-fg);
      width: fit-content;
      max-width: 100%;
      overflow-x: auto;
    }
    .bld-one-prompt { color: var(--accent); font-weight: 600; }
    .bld-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }
    .bld-file {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: var(--space-3);
      align-items: center;
      padding: var(--space-3) 0;
      border-bottom: 1px solid var(--rule);
      color: var(--foreground);
      font-family: var(--font-mono-display);
      font-size: var(--text-sm);
    }
    .bld-list li:last-child .bld-file { border-bottom: 0; }
    .bld-file:hover .bld-file-name { color: var(--accent); }
    .bld-file-name { font-weight: 500; }
    .bld-file-meta { display: inline-flex; gap: var(--space-2); align-items: center; color: var(--ink-faint); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--tracking-caps); }
    .bld-sep { color: var(--rule); }
    .bld-sha { font-feature-settings: 'ss02', 'ss03'; }

    .verify { padding-top: var(--space-10); display: flex; flex-direction: column; gap: var(--space-4); }
    .verify h2 { margin: 0; font-size: var(--text-lg); letter-spacing: -0.01em; }
    .verify-pre {
      margin: 0;
      padding: var(--space-5) var(--space-6);
      background: var(--syntax-bg);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-lg);
      font-family: var(--font-mono-display);
      font-size: var(--text-sm);
      line-height: 1.7;
      color: var(--syntax-fg);
      overflow-x: auto;
    }
    .verify-note { color: var(--muted-foreground); font-size: var(--text-sm); margin: 0; }
    .verify-note code {
      color: var(--foreground);
      background: var(--accent-soft);
      padding: 2px 6px;
      border-radius: var(--radius-sm);
      font-size: 0.92em;
    }

    @media (max-width: 800px) {
      .bld-grid { grid-template-columns: 1fr; gap: var(--space-6); }
    }
  </style>
</Base>
