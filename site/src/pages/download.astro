---
import Base from '../layouts/Base.astro';

const RELEASES_URL = 'https://github.com/ibrahemid/writ/releases';
const releaseAsset = (filename: string) => `${RELEASES_URL}/latest/download/${filename}`;

const builds = [
  {
    os: 'mac',
    name: 'macOS',
    sub: 'macOS 12 Monterey or later · Universal (Apple Silicon + Intel)',
    artefacts: [
      { label: 'Writ_0.1.0_universal.dmg', size: '—', href: releaseAsset('Writ_0.1.0_universal.dmg') },
    ],
    one: 'brew install --cask ibrahemid/writ/writ',
  },
  {
    os: 'win',
    name: 'Windows',
    sub: 'Windows 10 1809 or later · x86_64',
    artefacts: [
      { label: 'Writ_0.1.0_x64_en-US.msi', size: '—', href: releaseAsset('Writ_0.1.0_x64_en-US.msi') },
    ],
    one: 'winget install --id ibrahemid.Writ -e',
  },
  {
    os: 'linux',
    name: 'Linux',
    sub: 'glibc 2.31+ · x86_64',
    artefacts: [
      { label: 'Writ_0.1.0_amd64.deb',      size: '—', href: releaseAsset('Writ_0.1.0_amd64.deb') },
      { label: 'Writ_0.1.0_amd64.AppImage', size: '—', href: releaseAsset('Writ_0.1.0_amd64.AppImage') },
    ],
    one: 'curl -fsSL https://github.com/ibrahemid/writ/raw/main/install.sh | sh',
  },
];
---
<Base
  title="Download Writ"
  description="Install Writ. Real one-liners, signed binaries, SHA256 checksums. macOS, Windows, Linux."
  path="/download/"
  ogImage="/writ/brand/og-download.svg"
>
  <section class="dl">
    <div class="container dl-inner">
      <header class="dl-head">
        <span class="eyebrow">/* download · v0.1.0 */</span>
        <h1>Pick your shell.</h1>
        <p class="dl-sub">Signed builds. Same binary as the source. Verify checksums below if you care to.</p>
      </header>

      {builds.map((b) => (
        <article class="bld" id={b.os}>
          <hr class="rule" />
          <div class="bld-grid">
            <div class="bld-meta">
              <h2>{b.name}</h2>
              <p class="bld-sub">{b.sub}</p>
              <div class="bld-one">
                <span class="bld-one-prompt" aria-hidden="true">$</span>
                <code>{b.one}</code>
              </div>
            </div>
            <ul class="bld-list">
              {b.artefacts.map((a) => (
                <li>
                  <a href={a.href} class="bld-file" rel="noopener" target="_blank">
                    <span class="bld-file-name">{a.label}</span>
                    <span class="bld-file-meta">
                      <span>{a.size}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}

      <hr class="rule-thick" />
      <section class="firstrun">
        <h2>Updating Writ</h2>
        <p>
          Writ checks for updates on launch. When one is available, the app downloads
          and installs it in place, then relaunches itself. No drag-and-drop, no warnings.
        </p>
        <p class="muted">
          Manual reinstall (downloading a new <code>.dmg</code> and dragging it over)
          will fail with <em>"the item is in use"</em> because Writ is still running.
          To force a manual install, quit Writ first: <code>Cmd+Q</code> from the menu
          bar on macOS, right-click the dock icon and choose <em>Quit</em>, or run
          <code>pkill -f Writ</code> from a terminal.
        </p>
      </section>

      <hr class="rule-thick" />
      <section class="firstrun">
        <h2>First-time install</h2>
        <div class="firstrun-grid">
          <article>
            <h3>macOS</h3>
            <p>Writ is not notarized through Apple's paid Developer Program. The first time you open it, macOS will block the app. To allow it:</p>
            <ol>
              <li>Open the <code>.dmg</code> and drag Writ to Applications.</li>
              <li>Right-click Writ in Applications, choose <em>Open</em>.</li>
              <li>Click <em>Open</em> in the dialog.</li>
            </ol>
            <p class="muted">The warning only appears once. Auto-update and every later launch behave normally.</p>
          </article>
          <article>
            <h3>Windows</h3>
            <p>Windows SmartScreen may show <em>Windows protected your PC</em> on first run of the <code>.msi</code>. To install:</p>
            <ol>
              <li>Click <em>More info</em>.</li>
              <li>Click <em>Run anyway</em>.</li>
            </ol>
            <p class="muted">SmartScreen reputation builds with downloads, so the warning eases over time.</p>
          </article>
          <article>
            <h3>Linux</h3>
            <p>No warnings. Two paths:</p>
            <ol>
              <li><code>sudo dpkg -i Writ_&lt;version&gt;_amd64.deb</code> for system-wide install.</li>
              <li><code>chmod +x</code> the AppImage and run it directly for portable use.</li>
            </ol>
            <p class="muted">Or use the one-liner above for an automatic AppImage install into <code>~/.local/bin</code>.</p>
          </article>
        </div>
      </section>

      <hr class="rule-thick" />
      <section class="verify">
        <h2>Verify a download</h2>
        <pre class="verify-pre"><code>{`# Compare the SHA256 against SHA256SUMS.txt published with the release.
shasum -a 256 -c SHA256SUMS.txt`}</code></pre>
        <p class="verify-note">
          Each release ships a <code>SHA256SUMS.txt</code> covering every installer.
          The Tauri updater bundles (<code>.app.tar.gz.sig</code>, <code>.msi.zip.sig</code>,
          <code>.AppImage.tar.gz.sig</code>) are ed25519-signed with the project's
          updater key; verification happens automatically inside the in-app updater.
        </p>
      </section>
    </div>
  </section>

  <style>
    .dl { padding: var(--space-12) 0 var(--space-16); }
    .dl-inner { display: flex; flex-direction: column; gap: var(--space-12); }
    .dl-head { display: flex; flex-direction: column; gap: var(--space-3); }
    .dl-head h1 {
      margin: 0;
      font-size: var(--text-3xl);
      letter-spacing: -0.025em;
    }
    .dl-sub { color: var(--muted-foreground); margin: 0; max-width: 56ch; }

    .bld { padding-top: var(--space-8); }
    .bld-grid {
      display: grid;
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      gap: var(--space-10);
      align-items: start;
      padding-top: var(--space-6);
    }
    .bld-meta { display: flex; flex-direction: column; gap: var(--space-3); }
    .bld-meta h2 {
      margin: 0;
      font-size: var(--text-xl);
      letter-spacing: -0.015em;
    }
    .bld-sub { color: var(--muted-foreground); margin: 0; font-size: var(--text-sm); }
    .bld-one {
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-3) var(--space-4);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-md);
      background: var(--syntax-bg);
      font-family: var(--font-mono-display);
      color: var(--syntax-fg);
      width: fit-content;
      max-width: 100%;
      overflow-x: auto;
    }
    .bld-one-prompt { color: var(--accent); font-weight: 600; }
    .bld-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }
    .bld-file {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: var(--space-3);
      align-items: center;
      padding: var(--space-3) 0;
      border-bottom: 1px solid var(--rule);
      color: var(--foreground);
      font-family: var(--font-mono-display);
      font-size: var(--text-sm);
    }
    .bld-list li:last-child .bld-file { border-bottom: 0; }
    .bld-file:hover .bld-file-name { color: var(--accent); }
    .bld-file-name { font-weight: 500; }
    .bld-file-meta { display: inline-flex; gap: var(--space-2); align-items: center; color: var(--ink-faint); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--tracking-caps); }

    .firstrun { padding-top: var(--space-10); display: flex; flex-direction: column; gap: var(--space-6); }
    .firstrun h2 { margin: 0; font-size: var(--text-lg); letter-spacing: -0.01em; }
    .firstrun-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-8);
    }
    .firstrun article { display: flex; flex-direction: column; gap: var(--space-3); }
    .firstrun h3 { margin: 0; font-size: var(--text-base); letter-spacing: -0.01em; }
    .firstrun p { margin: 0; color: var(--foreground); }
    .firstrun ol { margin: 0; padding-left: var(--space-5); display: flex; flex-direction: column; gap: var(--space-1); color: var(--foreground); }
    .firstrun code {
      font-family: var(--font-mono);
      font-size: 0.9em;
      padding: 0.05em 0.35em;
      background: var(--accent);
      border-radius: 3px;
    }
    .firstrun .muted { color: var(--muted-foreground); font-size: var(--text-sm); }
    @media (max-width: 720px) {
      .firstrun-grid { grid-template-columns: 1fr; }
    }
    .verify { padding-top: var(--space-10); display: flex; flex-direction: column; gap: var(--space-4); }
    .verify h2 { margin: 0; font-size: var(--text-lg); letter-spacing: -0.01em; }
    .verify-pre {
      margin: 0;
      padding: var(--space-5) var(--space-6);
      background: var(--syntax-bg);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-lg);
      font-family: var(--font-mono-display);
      font-size: var(--text-sm);
      line-height: 1.7;
      color: var(--syntax-fg);
      overflow-x: auto;
    }
    .verify-note { color: var(--muted-foreground); font-size: var(--text-sm); margin: 0; }
    .verify-note code {
      color: var(--foreground);
      background: var(--accent-soft);
      padding: 2px 6px;
      border-radius: var(--radius-sm);
      font-size: 0.92em;
    }

    @media (max-width: 800px) {
      .bld-grid { grid-template-columns: 1fr; gap: var(--space-6); }
    }
  </style>
</Base>
