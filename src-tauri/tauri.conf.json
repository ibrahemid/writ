{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "Writ",
    "version": "0.1.0-2",
    "identifier": "com.writ.editor",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": false,
        "macOSPrivateApi": true,
        "windows": [
            {
                "title": "Writ",
                "width": 1100,
                "height": 720,
                "minWidth": 720,
                "minHeight": 480,
                "resizable": true,
                "decorations": false,
                "transparent": true,
                "visible": true,
                "center": true,
                "shadow": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://github.com https://*.githubusercontent.com; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-src writ-preview:; frame-ancestors 'none'"
        }
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/ibrahemid/writ/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2N0FEMTFEOTZDRTIxRjYKUldUMkljNldIZEY2NXFmOWtBU2RaZDFYWldrVUpiVFpHQ0NFY25ZSzVEbENTRGJLTkVRWC9PSGsK"
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "app",
            "dmg",
            "msi",
            "deb",
            "appimage"
        ],
        "createUpdaterArtifacts": true,
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "category": "DeveloperTool",
        "shortDescription": "Lightweight text editor for developers",
        "longDescription": "Writ is a distraction-free, always-ready scratchpad editor for developers. Global hotkey summon, autosave, full-text search, CodeMirror 6 with language detection. Local-only, zero telemetry.",
        "publisher": "Ibrahem ID",
        "copyright": "Copyright (c) 2026 Ibrahem ID",
        "macOS": {
            "minimumSystemVersion": "10.15"
        },
        "windows": {
            "wix": {
                "language": [
                    "en-US"
                ]
            }
        },
        "linux": {
            "deb": {
                "depends": [
                    "libwebkit2gtk-4.1-0",
                    "libgtk-3-0"
                ]
            },
            "appimage": {
                "bundleMediaFramework": false
            }
        },
        "fileAssociations": [
            {
                "ext": [
                    "txt",
                    "text",
                    "log"
                ],
                "name": "Plain Text",
                "mimeType": "text/plain",
                "role": "Editor"
            },
            {
                "ext": [
                    "md",
                    "markdown"
                ],
                "name": "Markdown",
                "mimeType": "text/markdown",
                "role": "Editor"
            },
            {
                "ext": [
                    "json"
                ],
                "name": "JSON",
                "mimeType": "application/json",
                "role": "Editor"
            },
            {
                "ext": [
                    "yaml",
                    "yml"
                ],
                "name": "YAML",
                "mimeType": "text/yaml",
                "role": "Editor"
            },
            {
                "ext": [
                    "toml"
                ],
                "name": "TOML",
                "mimeType": "text/x-toml",
                "role": "Editor"
            },
            {
                "ext": [
                    "rs"
                ],
                "name": "Rust",
                "mimeType": "text/x-rust",
                "role": "Editor"
            },
            {
                "ext": [
                    "js",
                    "jsx",
                    "mjs"
                ],
                "name": "JavaScript",
                "mimeType": "text/javascript",
                "role": "Editor"
            },
            {
                "ext": [
                    "ts",
                    "tsx",
                    "mts"
                ],
                "name": "TypeScript",
                "mimeType": "text/typescript",
                "role": "Editor"
            },
            {
                "ext": [
                    "py"
                ],
                "name": "Python",
                "mimeType": "text/x-python",
                "role": "Editor"
            },
            {
                "ext": [
                    "go"
                ],
                "name": "Go",
                "mimeType": "text/x-go",
                "role": "Editor"
            },
            {
                "ext": [
                    "html",
                    "htm"
                ],
                "name": "HTML",
                "mimeType": "text/html",
                "role": "Editor"
            },
            {
                "ext": [
                    "css",
                    "scss",
                    "less"
                ],
                "name": "CSS",
                "mimeType": "text/css",
                "role": "Editor"
            },
            {
                "ext": [
                    "xml",
                    "svg"
                ],
                "name": "XML",
                "mimeType": "text/xml",
                "role": "Editor"
            },
            {
                "ext": [
                    "sql"
                ],
                "name": "SQL",
                "mimeType": "application/sql",
                "role": "Editor"
            },
            {
                "ext": [
                    "sh",
                    "bash",
                    "zsh"
                ],
                "name": "Shell Script",
                "mimeType": "text/x-shellscript",
                "role": "Editor"
            },
            {
                "ext": [
                    "java",
                    "kt",
                    "kts"
                ],
                "name": "Java/Kotlin",
                "mimeType": "text/x-java-source",
                "role": "Editor"
            },
            {
                "ext": [
                    "c",
                    "h",
                    "cpp",
                    "cc",
                    "hpp"
                ],
                "name": "C/C++",
                "mimeType": "text/x-c",
                "role": "Editor"
            },
            {
                "ext": [
                    "swift"
                ],
                "name": "Swift",
                "mimeType": "text/x-swift",
                "role": "Editor"
            },
            {
                "ext": [
                    "rb"
                ],
                "name": "Ruby",
                "mimeType": "text/x-ruby",
                "role": "Editor"
            },
            {
                "ext": [
                    "php"
                ],
                "name": "PHP",
                "mimeType": "text/x-php",
                "role": "Editor"
            },
            {
                "ext": [
                    "ini",
                    "cfg",
                    "conf",
                    "env"
                ],
                "name": "Config",
                "mimeType": "text/plain",
                "role": "Editor"
            },
            {
                "ext": [
                    "csv"
                ],
                "name": "CSV",
                "mimeType": "text/csv",
                "role": "Editor"
            },
            {
                "ext": [
                    "graphql",
                    "gql"
                ],
                "name": "GraphQL",
                "mimeType": "application/graphql",
                "role": "Editor"
            },
            {
                "ext": [
                    "dockerfile"
                ],
                "name": "Dockerfile",
                "mimeType": "text/x-dockerfile",
                "role": "Editor"
            }
        ]
    }
}
