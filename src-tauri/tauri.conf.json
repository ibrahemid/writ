{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "Writ",
    "version": "0.1.0",
    "identifier": "com.writ.editor",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": false,
        "windows": [
            {
                "title": "Writ",
                "width": 800,
                "height": 600,
                "resizable": true,
                "decorations": false,
                "visible": true,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": ["app", "dmg"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "category": "DeveloperTool",
        "shortDescription": "Lightweight text editor for developers",
        "fileAssociations": [
            {
                "ext": ["txt", "text", "log"],
                "name": "Plain Text",
                "mimeType": "text/plain",
                "role": "Editor"
            },
            {
                "ext": ["md", "markdown"],
                "name": "Markdown",
                "mimeType": "text/markdown",
                "role": "Editor"
            },
            {
                "ext": ["json"],
                "name": "JSON",
                "mimeType": "application/json",
                "role": "Editor"
            },
            {
                "ext": ["yaml", "yml"],
                "name": "YAML",
                "mimeType": "text/yaml",
                "role": "Editor"
            },
            {
                "ext": ["toml"],
                "name": "TOML",
                "mimeType": "text/x-toml",
                "role": "Editor"
            },
            {
                "ext": ["rs"],
                "name": "Rust",
                "mimeType": "text/x-rust",
                "role": "Editor"
            },
            {
                "ext": ["js", "jsx", "mjs"],
                "name": "JavaScript",
                "mimeType": "text/javascript",
                "role": "Editor"
            },
            {
                "ext": ["ts", "tsx", "mts"],
                "name": "TypeScript",
                "mimeType": "text/typescript",
                "role": "Editor"
            },
            {
                "ext": ["py"],
                "name": "Python",
                "mimeType": "text/x-python",
                "role": "Editor"
            },
            {
                "ext": ["go"],
                "name": "Go",
                "mimeType": "text/x-go",
                "role": "Editor"
            },
            {
                "ext": ["html", "htm"],
                "name": "HTML",
                "mimeType": "text/html",
                "role": "Editor"
            },
            {
                "ext": ["css", "scss", "less"],
                "name": "CSS",
                "mimeType": "text/css",
                "role": "Editor"
            },
            {
                "ext": ["xml", "svg"],
                "name": "XML",
                "mimeType": "text/xml",
                "role": "Editor"
            },
            {
                "ext": ["sql"],
                "name": "SQL",
                "mimeType": "application/sql",
                "role": "Editor"
            },
            {
                "ext": ["sh", "bash", "zsh"],
                "name": "Shell Script",
                "mimeType": "text/x-shellscript",
                "role": "Editor"
            },
            {
                "ext": ["java", "kt", "kts"],
                "name": "Java/Kotlin",
                "mimeType": "text/x-java-source",
                "role": "Editor"
            },
            {
                "ext": ["c", "h", "cpp", "cc", "hpp"],
                "name": "C/C++",
                "mimeType": "text/x-c",
                "role": "Editor"
            },
            {
                "ext": ["swift"],
                "name": "Swift",
                "mimeType": "text/x-swift",
                "role": "Editor"
            },
            {
                "ext": ["rb"],
                "name": "Ruby",
                "mimeType": "text/x-ruby",
                "role": "Editor"
            },
            {
                "ext": ["php"],
                "name": "PHP",
                "mimeType": "text/x-php",
                "role": "Editor"
            },
            {
                "ext": ["ini", "cfg", "conf", "env"],
                "name": "Config",
                "mimeType": "text/plain",
                "role": "Editor"
            },
            {
                "ext": ["csv"],
                "name": "CSV",
                "mimeType": "text/csv",
                "role": "Editor"
            },
            {
                "ext": ["graphql", "gql"],
                "name": "GraphQL",
                "mimeType": "application/graphql",
                "role": "Editor"
            },
            {
                "ext": ["dockerfile"],
                "name": "Dockerfile",
                "mimeType": "text/x-dockerfile",
                "role": "Editor"
            }
        ]
    }
}
