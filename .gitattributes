# Default to auto-normalized line endings for text files.
* text=auto eol=lf

# Explicit text formats.
*.rs         text eol=lf
*.toml       text eol=lf
*.md         text eol=lf
*.mdx        text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.js         text eol=lf
*.jsx        text eol=lf
*.json       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.scss       text eol=lf
*.sh         text eol=lf
*.py         text eol=lf
Cargo.toml   text eol=lf
Cargo.lock   text eol=lf linguist-generated=true

# Windows batch and PowerShell scripts need CRLF.
*.bat        text eol=crlf
*.ps1        text eol=crlf

# Binary formats.
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.webp       binary
*.ico        binary
*.icns       binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.otf        binary
*.mp4        binary
*.mov        binary
*.webm       binary
*.pdf        binary
*.zip        binary
*.gz         binary
*.tar        binary

# Lockfiles: treat as generated for diff suppression and linguist stats.
pnpm-lock.yaml       linguist-generated=true
package-lock.json    linguist-generated=true
yarn.lock            linguist-generated=true
